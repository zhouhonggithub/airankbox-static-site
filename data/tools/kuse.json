    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"AI智能画布\",\n\t\t\t\"description\": \"提供一个集成的AI工作空间， 用户可以在画布上自由布局和组织各种内容， 包括文本、 图片、 文档等， 实现可视化的内容管理和协作。 \"\n\t\t}, {\n\t\t\t\"name\": \"多媒体内容对话\",\n\t\t\t\"description\": \"支持与文件、链接和视频进行智能对话，AI能够理解和分析各种格式的内容，并提供相关的洞察和建议。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"文档格式化工具\",\n\t\t\t\"description\": \"上传模板后，AI能够瞬间分析文档布局，实现完美的格式复制和重现，大大提高文档处理效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"考试卷生成器\",\n\t\t\t\"description\": \"基于上传的模板，AI分析布局结构后能够立即生成符合要求的考试试卷，适用于教育工作者和培训机构。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"内容洞察分析\",\n\t\t\t\"description\": \"将各种类型的内容转化为可操作的洞察和建议，帮助用户从复杂信息中提取关键要点和行动指南。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"教育工作者\",\n\t\t\t\"description\": \"教师和培训师可以使用考试卷生成器快速创建测试题目，使用文档格式化工具处理教学材料，提高教学准备效率。\"\n\t\t}, {\n\t\t\t\"name\": \"内容创作者\",\n\t\t\t\"description\": \"自媒体作者、博主可以利用AI画布整理创作素材，通过多媒体对话功能分析视频和文档内容，获得创作灵感。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"研究人员\",\n\t\t\t\"description\": \"学术研究人员可以使用平台分析大量文献和资料，通过AI对话功能快速提取关键信息和研究洞察。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"商务人士\",\n\t\t\t\"description\": \"商务专业人士可以利用文档处理功能整理会议资料，使用AI分析功能从商业文档中获得战略洞察。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\"name\": \"可视化AI工作空间\",\n\t\t\"description\": \"提供直观的画布界面，用户可以自由拖拽和排列各种内容元素，创建个性化的工作空间布局。\"\n\t}, {\n\t\t\"name\": \"多格式内容支持\",\n\t\t\"description\": \"支持处理文档、图片、视频、链接等多种格式的内容，实现真正的全媒体AI交互体验。\"\n\t}, {\n\t\t\"name\": \"智能布局分析\",\n\t\t\"description\": \"具备强大的文档布局识别和分析能力，能够准确理解复杂文档的结构和格式要求。\"\n\t}, {\n\t\t\"name\": \"实时协作功能\",\n\t\t\"description\": \"支持多人同时在同一画布上工作，实现高效的团队协作和知识共享。\"\n\t}],\n\t\"scenarios\": [{\n\t\t\"name\": \"教学内容准备\",\n\t\t\"description\": \"教师准备新学期课程时，可以在AI画布上整理教学大纲、参考资料和多媒体内容。使用文档格式化工具标准化教案格式， 通过考试卷生成器根据教学内容自动创建相应的测试题目， 大大减少备课时间。 \"\n\t}, {\n\t\t\"name \": \"研究资料分析\",\n\t\t\"description\": \"研究人员收集了大量PDF论文、视频讲座和网络资料后，可以将这些内容导入AI画布， 通过对话功能快速分析每个资料的核心观点， AI会帮助提取关键信息并生成研究洞察报告。 \"\n\t}, {\n\t\t\"name\": \"商业文档处理\",\n\t\t\"description\": \"企业在准备重要提案时，需要处理各种格式的市场报告、财务数据和竞品分析。使用Kuse AI可以在画布上整合所有信息， 通过AI分析功能识别关键趋势和商业机会， 最后使用文档格式化工具生成专业的提案文档。 \"\n\t}, {\n\t\t\"name\": \"内容创作规划\",\n\t\t\"description\": \"自媒体创作者在策划新的系列内容时，可以在画布上收集相关的视频素材、参考文章和灵感图片。通过与这些内容对话， AI会提供创作建议和内容结构， 帮助创作者形成完整的内容规划和制作时间表。 \"\n\t}],\n\t\"pricing_plan \": [{\n\t\t\"name\": \"免费体验版\",\n\t\t\"description\": \"提供基础的AI画布功能和有限的文档处理次数，适合个人用户试用和轻度使用场景。\"\n\t}, {\n\t\t\"name\": \"专业版\",\n\t\t\"description\": \"解锁全部功能包括无限制的文档处理、高级AI分析和协作功能，适合专业用户和小团队使用。\"\n\t}, {\n\t\t\"name\": \"企业版\",\n\t\t\"description\": \"提供定制化解决方案、API接入和专属技术支持，适合大型企业和机构的深度集成需求。\"\n\t}],\n\t\"usage\": [{\n\t\t\"name\": \"网页端使用\",\n\t\t\"description\": \"用户访问app.kuse.ai即可开始使用，无需下载安装。首次使用可以选择访客模式快速体验功能。在AI画布上，用户可以通过拖拽方式添加各种内容元素， 包括上传文档、 粘贴链接或嵌入视频。 然后可以与这些内容进行自然语言对话， AI会分析内容并提供相关洞察。 对于文档格式化， 只需上传模板文件， AI会自动分析并提供格式化建议。 \"\n\t}, {\n\t\t\"name\": \"协作模式使用\",\n\t\t\"description\": \"团队成员可以共享同一个画布进行协作，每个人可以添加自己的内容和见解。 系统支持实时同步， 所有变更都会立即显示给其他协作者。 团队可以使用AI功能集体分析复杂项目，通过对话功能获得不同角度的洞察， 最终形成综合性的解决方案。 \"\n\t}]\n}",
