    "htmlContent": "{\n  \"title\": \"Fairies AI\",\n  \"url\": \"https://fairies.ai\",\n  \"functions\": [\n    {\n      \"name\": \"多任务执行能力\",\n      \"description\": \"支持超过1000种操作，包括文件管理、代码生成、邮件发送、日程安排等各类任务。\"\n    },\n    {\n      \"name\": \"自然语言交互\",\n      \"description\": \"用户可以通过自然语言与Fairies交流，它能理解并准确执行复杂的用户需求。\"\n    },\n    {\n      \"name\": \"深度研究与分析\",\n      \"description\": \"提供深入的研究和数据分析功能，自动总结行业新闻、分析竞争对手定价策略等。\"\n    },\n    {\n      \"name\": \"应用集成\",\n      \"description\": \"与Slack、Gmail、Google Drive、Notion、GitHub等数百种常用应用无缝集成。\"\n    },\n    {\n      \"name\": \"端到端加密\",\n      \"description\": \"采用最高级别的安全保护，所有数据处理在本地完成，确保用户隐私绝对安全。\"\n    },\n    {\n      \"name\": \"模型选择\",\n      \"description\": \"支持多款顶级AI模型，包括GPT-4.1、Gemini 2.5 Pro、Claude 4等最新版本。\"\n    },\n    {\n      \"name\": \"人机协作\",\n      \"description\": \"在执行重要操作前会请求用户确认，确保每一步操作都安全可控。\"\n    },\n    {\n      \"name\": \"桌面原生体验\",\n      \"description\": \"真正生活在你的电脑上，提供比传统AI助手更深度的系统级交互。\"\n    },\n    {\n      \"name\": \"工作流自动化\",\n      \"description\": \"支持复杂的多步骤任务自动化，大幅提升工作效率。\"\n    },\n    {\n      \"name\": \"MCP协议支持\",\n      \"description\": \"支持模型上下文协议，实现更丰富的AI功能扩展。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"软件开发者\",\n      \"description\": \"自动化代码生成、代码审查、部署流程，与GitHub等开发工具深度集成。\"\n    },\n    {\n      \"name\": \"产品经理\",\n      \"description\": \"快速收集市场信息、分析竞品、生成产品文档和路线图。\"\n    },\n    {\n      \"name\": \"研究人员\",\n      \"description\": \"深度研究、文献检索、数据分析和报告生成，提升研究效率。\"\n    },\n    {\n      \"name\": \"企业管理者\",\n      \"description\": \"自动化日程管理、邮件处理、团队协调和战略分析。\"\n    },\n    {\n      \"name\": \"创意工作者\",\n      \"description\": \"内容创作、设计辅助、创意构思和项目管理自动化。\"\n    },\n    {\n      \"name\": \"运营人员\",\n      \"description\": \"数据分析、报告生成、客户沟通和流程优化自动化。\"\n    },\n    {\n      \"name\": \"创业者\",\n      \"description\": \"一站式解决业务流程自动化，从市场调研到产品开发的全方位支持。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"北大校友创立\",\n      \"description\": \"由北大物理系校友Robert Yang创立，团队具备深厚的AI研究背景。\"\n    },\n    {\n      \"name\": \"Project Sid成功经验\",\n      \"description\": \"曾成功打造1000个AI智能体的《我的世界》社会实验。\"\n    },\n    {\n      \"name\": \"跨平台支持\",\n      \"description\": \"完美支持macOS和Windows系统，提供原生应用体验。\"\n    },\n    {\n      \"name\": \"免费试用\",\n      \"description\": \"提供免费版本无限聊天，专业版每月仅需20美元。\"\n    },\n    {\n      \"name\": \"即时可用\",\n      \"description\": \"无需邀请码，下载即可立即开始使用。\"\n    },\n    {\n      \"name\": \"持续演进\",\n      \"description\": \"基于最新AI技术，定期更新添加新功能和支持更多应用。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"文件管理自动化\",\n      \"description\": \"\\\"将桌面上的非图片类文件放入废纸篓\\\" - 18秒完成复杂文件筛选操作。\"\n    },\n    {\n      \"name\": \"团队协作\",\n      \"description\": \"\\\"帮助团队安排一个合适的会议时间\\\" - 自动分析日程并发送会议通知。\"\n    },\n    {\n      \"name\": \"购物决策\",\n      \"description\": \"\\\"推荐一台最适合工作的Mac电脑\\\" - 提供详细产品对比和购买建议。\"\n    },\n    {\n      \"name\": \"邮件处理\",\n      \"description\": \"\\\"将电子邮件线程转换为PDF文档\\\" - 快速整理和归档重要邮件。\"\n    },\n    {\n      \"name\": \"定时提醒\",\n      \"description\": \"\\\"每天早上9点发送Slack消息，告知当天的日程安排\\\" - 智能日程管理。\"\n    }\n  ]\n}",
