    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"智能文本生成\",\n      \"description\": \"根据用户输入的关键词或主题，自动生成高质量的文本内容，支持多种文体和格式。\"\n    },\n    {\n      \"name\": \"写作建议\",\n      \"description\": \"提供实时的写作建议和修改意见，帮助用户优化文本结构和语言表达。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"学生\",\n      \"description\": \"帮助学生快速完成论文、作业等学术写作任务，提高写作效率和质量。\"\n    },\n    {\n      \"name\": \"教育人士\",\n      \"description\": \"辅助教师生成教学材料、教案和学术论文，减轻写作负担。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"多场景适用\",\n      \"description\": \"支持论文、公文、小说等多种写作场景，满足不同用户的写作需求。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"学术论文写作\",\n      \"description\": \"用户输入论文主题和关键词，系统自动生成论文大纲和部分内容，帮助用户快速完成学术写作。\"\n    },\n    {\n      \"name\": \"公文写作\",\n      \"description\": \"根据用户提供的公文类型和内容要求，生成符合规范的公文文本，提高办公效率。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费试用\",\n      \"description\": \"提供基础功能试用，适合新用户体验工具的基本功能。\"\n    },\n    {\n      \"name\": \"高级会员\",\n      \"description\": \"解锁全部功能，包括高级文本生成和个性化写作建议，适合高频用户。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页版使用\",\n      \"description\": \"用户可以直接访问SongGuoAI官网，注册账号后即可开始使用。在输入框中输入写作主题或关键词，系统会自动生成相关内容。用户可以根据需要调整和修改生成的内容。\"\n    },\n    {\n      \"name\": \"API集成\",\n      \"description\": \"开发者可以通过API将SongGuoAI的文本生成功能集成到自己的应用中。具体集成方法可以参考官方文档，提供详细的API调用示例和参数说明。\"\n    }\n  ]\n}",
