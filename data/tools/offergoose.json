    "screenshot_url": null,
    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"智能面试模拟\",\n      \"description\": \"OfferGoose提供高度真实的面试模拟环境，涵盖多种行业和职位。系统会根据用户选择的职位类型，生成相应的面试问题，并模拟面试官的提问方式。用户可以通过语音或文字回答，系统会实时分析回答内容，提供反馈和建议。\"\n    },\n    {\n      \"name\": \"个性化反馈\",\n      \"description\": \"平台会对用户的面试表现进行详细分析，包括语言表达、逻辑思维、专业知识等方面。系统会生成个性化的改进建议，帮助用户发现不足并提升面试技巧。反馈内容具体且可操作，用户可以据此进行针对性练习。\"\n    },\n    {\n      \"name\": \"面试题库\",\n      \"description\": \"OfferGoose拥有庞大的面试题库，涵盖技术、管理、销售等多种职位类型。题库内容定期更新，确保与当前市场需求同步。用户可以根据自身需求选择特定类型的题目进行练习，提升应对不同面试场景的能力。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"学生\",\n      \"description\": \"学生可以使用OfferGoose进行面试准备，尤其是即将毕业或寻找实习机会的学生。通过反复练习和系统反馈，学生可以提前熟悉面试流程，减少实际面试时的紧张感，提高通过率。\"\n    },\n    {\n      \"name\": \"教育人士\",\n      \"description\": \"教育人士（如职业指导老师）可以利用OfferGoose作为教学工具，帮助学生或学员提升面试技巧。平台提供的详细反馈和分析可以作为教学参考，帮助教育人士更有效地指导学生。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"内容创作者（如职业咨询博主）可以通过OfferGoose获取面试相关的素材和案例，用于制作内容。平台的题库和反馈机制可以为创作者提供真实、有价值的信息，增强内容的专业性和实用性。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"高度真实的模拟体验\",\n      \"description\": \"OfferGoose的面试模拟环境高度接近真实面试场景，包括语音识别、自然语言处理等技术，确保用户获得逼真的练习体验。系统能够识别用户的语气、停顿等细节，提供更全面的反馈。\"\n    },\n    {\n      \"name\": \"个性化学习路径\",\n      \"description\": \"平台会根据用户的练习记录和反馈结果，生成个性化的学习路径。用户可以根据系统推荐的重点领域进行针对性练习，高效提升面试能力。\"\n    },\n    {\n      \"name\": \"多行业覆盖\",\n      \"description\": \"OfferGoose的题库涵盖多个行业和职位类型，满足不同用户的需求。无论是技术岗位还是非技术岗位，用户都能找到相关的练习内容。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"面试前的模拟练习\",\n      \"description\": \"用户收到面试邀请后，可以在OfferGoose上选择相应的职位类型进行模拟练习。系统会生成与真实面试相似的问题，用户通过语音或文字回答后，获得即时反馈和改进建议。反复练习后，用户能够更自信地应对实际面试。\"\n    },\n    {\n      \"name\": \"职业规划与准备\",\n      \"description\": \"对于尚未确定职业方向的用户，可以通过OfferGoose尝试不同职位的面试模拟，了解各职位的要求和自身匹配度。平台提供的反馈和建议可以帮助用户明确职业规划，提前做好相关技能的准备。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费试用\",\n      \"description\": \"OfferGoose提供免费试用功能，用户可以体验基础的面试模拟和反馈。免费版可能有一定的次数限制或功能限制，适合初次使用者尝试。\"\n    },\n    {\n      \"name\": \"付费会员\",\n      \"description\": \"付费会员可以享受无限制的面试模拟、更详细的反馈报告以及个性化学习路径。具体价格和功能需参考官网最新信息。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"快速开始面试模拟\",\n      \"description\": \"1. 访问OfferGoose官网并注册账号。\\n2. 选择目标职位类型和行业。\\n3. 开始模拟面试，通过语音或文字回答问题。\\n4. 查看系统生成的反馈报告，根据建议进行改进。\"\n    },\n    {\n      \"name\": \"个性化学习路径\",\n      \"description\": \"1. 完成首次面试模拟后，系统会生成个性化学习路径。\\n2. 根据系统推荐的重点领域选择练习题目。\\n3. 定期练习并跟踪进步情况。\\n4. 调整学习路径以适应新的面试需求。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"OfferGoose的面试模拟是否真实？\",\n      \"description\": \"是的，OfferGoose利用先进的自然语言处理和语音识别技术，模拟真实面试场景。系统会根据用户选择的职位类型生成相关问题，并提供接近真实面试官的反馈。\"\n    },\n    {\n      \"name\": \"如何提升面试通过率？\",\n      \"description\": \"通过反复练习OfferGoose提供的面试模拟，用户可以熟悉常见问题并优化回答方式。系统提供的个性化反馈和建议可以帮助用户发现不足并针对性改进，从而提升实际面试的通过率。\"\n    },\n    {\n      \"name\": \"OfferGoose是否适合所有行业？\",\n      \"description\": \"OfferGoose的题库涵盖多个行业和职位类型，包括技术、管理、销售等。用户可以根据自身需求选择相应的练习内容。如果某些特定行业未被覆盖，平台会定期更新题库以满足更多需求。\"\n    }\n  ]\n}",
