    "screenshot_url": null,
    "htmlContent": "{\n  \"name\": \"Kiro\",\n  \"description\": \"The AI IDE for prototype to production - 从原型到生产的AI集成开发环境\",\n  \"website\": \"https://kiro.dev/\",\n  \"functions\": [\n    {\n      \"name\": \"Spec-driven Development\",\n      \"description\": \"将你的提示转换为清晰的需求、系统设计和离散任务。与Kiro协作制定规范和架构，Kiro代理根据规范实施，同时保持你的控制权。\"\n    },\n    {\n      \"name\": \"Agent Hooks自动化\",\n      \"description\": \"将任务委托给AI代理，这些代理会在\\\"文件保存\\\"等事件时触发。代理根据预定义的提示在后台自主执行，帮助生成文档、单元测试或优化代码性能。\"\n    },\n    {\n      \"name\": \"Multimodal Chat\",\n      \"description\": \"支持多模态聊天，可以处理图像、文本等多种输入方式。可以上传UI设计图或架构白板照片，Kiro会用它来指导实现。\"\n    },\n    {\n      \"name\": \"Code Generation\",\n      \"description\": \"基于Claude Sonnet 3.7或Sonnet 4模型进行智能代码生成，支持多种编程语言，提供高质量的代码建议和实现。\"\n    },\n    {\n      \"name\": \"Autopilot Mode\",\n      \"description\": \"让Kiro自主运行大型任务，无需逐步指导。在运行脚本或命令时，你仍然保持控制权。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"软件工程师\",\n      \"description\": \"为需要高效开发流程的软件工程师提供AI辅助编程工具，从概念到工作原型的快速开发。\"\n    },\n    {\n      \"name\": \"全栈开发者\",\n      \"description\": \"支持全栈应用开发，从原型到生产环境的完整开发流程，特别适合需要快速迭代的项目。\"\n    },\n    {\n      \"name\": \"产品经理\",\n      \"description\": \"帮助产品经理快速将想法转化为可工作的原型，通过spec-driven development确保需求清晰传达。\"\n    },\n    {\n      \"name\": \"创业团队\",\n      \"description\": \"为创业团队提供快速MVP构建能力，在几天内从概念到工作原型，加速产品验证过程。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"VS Code兼容性\",\n      \"description\": \"支持导入VS Code扩展和设置，在流线型AI就绪环境中使用Open VSX插件、主题和VS Code设置。\"\n    },\n    {\n      \"name\": \"MCP集成\",\n      \"description\": \"通过原生MCP集成连接到文档、数据库、API等，让你可以在工作环境中带入你的世界。\"\n    },\n    {\n      \"name\": \"智能上下文管理\",\n      \"description\": \"通过规范、指导和智能上下文管理，Kiro理解提示背后的意图，帮助在大型代码库中实现复杂功能。\"\n    },\n    {\n      \"name\": \"代码差异视图\",\n      \"description\": \"实时查看代码变更，可以批准所有内容、逐步查看每个更改，或一键进行编辑。\"\n    },\n    {\n      \"name\": \"企业级安全\",\n      \"description\": \"提供企业级安全性和隐私保护，让你可以自信地交付最佳工作成果。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"快速原型开发\",\n      \"description\": \"从概念到工作原型在单个周末内完成，通过spec-driven development快速验证想法。\"\n    },\n    {\n      \"name\": \"安全应用开发\",\n      \"description\": \"在两天内从零开始构建安全文件共享应用，自动集成加密和各种安全编码实践。\"\n    },\n    {\n      \"name\": \"游戏开发\",\n      \"description\": \"即使没有游戏开发经验，也能快速创建游戏，Kiro处理逻辑并实现快速准确的代码编写。\"\n    },\n    {\n      \"name\": \"企业级项目\",\n      \"description\": \"适用于大型企业项目开发，提供完整的开发流程控制和代码质量保证。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费预览版\",\n      \"description\": \"Kiro在预览期间免费使用，提供完整功能体验，无需付费即可开始使用。\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"提供企业级功能，包括高级安全特性、团队协作和定制化服务（具体价格需查看官网）。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"快速开始\",\n      \"description\": \"1. 访问Kiro官网下载客户端。2. 安装并启动Kiro。3. 选择Claude Sonnet 3.7或Sonnet 4模型。4. 开始使用spec-driven development进行项目开发。\"\n    },\n    {\n      \"name\": \"Spec驱动开发\",\n      \"description\": \"1. 输入项目需求描述。2. Kiro生成清晰的需求和系统设计。3. 与Kiro协作完善规范。4. AI代理自动实施代码。5. 实时查看代码差异并批准更改。\"\n    },\n    {\n      \"name\": \"Agent Hooks配置\",\n      \"description\": \"1. 配置项目steering文件。2. 设置触发事件（如文件保存）。3. 定义AI代理的预定义提示。4. 让代理在后台自主执行任务。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"什么是spec-driven development？\",\n      \"description\": \"Spec-driven development是一种结构化的AI编码方法，将提示转换为清晰的需求、结构化设计、实施任务和由高级代理生成的代码，将AI编码流程提升到成熟的工程实践水平。\"\n    },\n    {\n      \"name\": \"如何开始使用Kiro？\",\n      \"description\": \"访问Kiro官网下载客户端，安装后选择AI模型，然后就可以开始使用spec-driven development进行项目开发。Kiro目前提供免费预览版。\"\n    },\n    {\n      \"name\": \"Kiro支持哪些编程语言？\",\n      \"description\": \"Kiro支持多种编程语言，具体支持的语言列表可以在官方文档中查看。它基于Claude模型，具有强大的多语言代码生成能力。\"\n    },\n    {\n      \"name\": \"可以导入现有IDE设置吗？\",\n      \"description\": \"是的，Kiro支持导入VS Code扩展和设置，包括Open VSX插件、主题和VS Code设置，在流线型AI就绪环境中使用。\"\n    }\n  ]\n}",
