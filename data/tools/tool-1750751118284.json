    "htmlContent": "{\n  \"title\": \"造梦日记\",\n  \"url\": \"https://zmrj.art/\",\n  \"functions\": [\n    {\n      \"name\": \"AI图像生成\",\n      \"description\": \"基于AI算法，输入文字或图片即可生成高质量图片，支持中英文提示词输入。\"\n    },\n    {\n      \"name\": \"多风格图像创作\",\n      \"description\": \"支持油画、水彩、哑光画、儿童画、素描、中国风、电影感、摄影、动漫风、游戏场景、吉卜力、低聚艺术、像素艺术、CG渲染、赛博朋克、蒸汽波、虚幻引擎、印象主义、未来主义、超现实主义、浮世绘、室内设计等海量风格。\"\n    },\n    {\n      \"name\": \"艺术大师风格模仿\",\n      \"description\": \"可以模仿毕加索、梵高、莫奈、丰子恺、永井博、保罗·塞尚、托马斯·科尔、约翰·哈利斯、马克·西莫内蒂、托马斯·金凯德、西尔文·塞瑞尔等艺术大师的创作风格。\"\n    },\n    {\n      \"name\": \"多尺寸支持\",\n      \"description\": \"支持1:1、16:9、9:16、3:4、4:3等多种尺寸和分辨率的图像生成，可根据画面内容选择相应尺寸。\"\n    },\n    {\n      \"name\": \"定制模型训练\",\n      \"description\": \"用户可上传对应要求的图像后训练生成限定款图片或自推理生成图片，定制模型的训练时间约需30分钟。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"设计师\",\n      \"description\": \"为平面设计师、插画师提供快速创意图像生成，支持商业设计和创意表达。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"为自媒体、博主、作家提供配图和插画创作，丰富内容视觉表现。\"\n    },\n    {\n      \"name\": \"艺术爱好者\",\n      \"description\": \"为艺术爱好者提供创意表达平台，轻松创作各种风格的艺术作品。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"西湖大学技术支持\",\n      \"description\": \"由西湖大学深度学习实验室和西湖心辰（Friday AI 写作助手背后的团队）联合出品，技术实力雄厚。\"\n    },\n    {\n      \"name\": \"超强算力支持\",\n      \"description\": \"拥有超强算力支持，实现超快出图速度，提升用户体验。\"\n    },\n    {\n      \"name\": \"多端支持\",\n      \"description\": \"目前支持微信小程序和网页端等多个平台，使用便捷。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"创意设计场景\",\n      \"description\": \"设计师可以通过输入创意描述快速生成多种风格的设计稿，比如输入'科技感十足的产品海报设计'，选择相应的风格和尺寸，即可获得多个设计方案，大大提升设计效率和创意灵感。\"\n    },\n    {\n      \"name\": \"内容配图场景\",\n      \"description\": \"自媒体运营者在撰写文章时，可以根据文章主题生成匹配的插图，比如写一篇关于春天的文章，输入'春天的樱花盛开，阳光明媚'等描述，选择合适的艺术风格，即可获得精美的配图。\"\n    },\n    {\n      \"name\": \"个人创作场景\",\n      \"description\": \"普通用户可以将自己的想象或梦境转化为视觉作品，比如输入一句诗词、歌词或者emoji表情，平台会根据这些输入生成对应的艺术图像，让抽象的想法变成具体的视觉表达。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费额度\",\n      \"description\": \"新用户注册后可免费获得100颗造梦星，每日签到可领取一定数量的星星，用于兑换图片生成服务。\"\n    },\n    {\n      \"name\": \"月卡会员 50元\",\n      \"description\": \"每月50元，可以获得600颗造梦星，享受更快速度和更多尺寸的出图服务。\"\n    },\n    {\n      \"name\": \"季卡会员 128元\",\n      \"description\": \"3个月128元，可以获得2000颗造梦星，享受VIP专属服务和优先处理。\"\n    },\n    {\n      \"name\": \"年卡会员 388元\",\n      \"description\": \"12个月388元，可以获得8000颗造梦星，性价比最高的选择。\"\n    },\n    {\n      \"name\": \"摘星套餐\",\n      \"description\": \"按需购买造梦星：12元150颗、40元600颗、148元2500颗，适合偶尔使用的用户。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"用户首先访问造梦日记官网(https://zmrj.art/)，点击'开始创作'按钮进入生成页面。在页面中选择造梦画板或ControlNet画板，然后在文本框中描述想要生成的画面场景，可以是具体的物品描述、场景描述、诗句、歌词甚至emoji表情。接下来选择喜欢的艺术风格，如写真、流光、摄影、动漫风等，还可以上传参考图片。最后选择合适的图像尺寸和生成数量，点击生成按钮即可。整个过程简单直观，支持中英文输入，生成速度快。\"\n    },\n    {\n      \"name\": \"微信小程序使用\",\n      \"description\": \"用户可以在微信中搜索'造梦日记'小程序，打开后即可开始使用。小程序版本针对移动端进行了优化，界面简洁易用。使用流程与网页端类似：输入描述文字、选择风格、设置参数、生成图片。小程序的优势在于随时随地都能使用，无需下载安装，且与微信生态完美整合，生成的图片可以直接分享到微信朋友圈或发送给好友。对于经常使用手机的用户来说，小程序版本更加便捷实用。\"\n    },\n    {\n      \"name\": \"定制模型训练\",\n      \"description\": \"对于有特殊需求的用户，造梦日记提供定制模型训练功能。用户需要先准备一组符合要求的训练图片（通常需要10-20张同类型或同风格的图片），然后上传到平台进行模型训练。训练时间约为30分钟，训练完成后用户就拥有了专属的AI模型，可以生成特定风格或特定对象的图片。这个功能特别适合品牌方、设计师或有特殊创作需求的用户，可以生成符合品牌调性或个人风格的专属图像内容。\"\n    }\n  ]\n}",
