    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"AI面试辅助\",\n\t\t\t\"description\": \"通过实时语音识别技术，精准捕捉面试官的问题，并利用AI大模型（如GPT-4）在毫秒级内生成高质量的回答建议，帮助用户在面试中从容应对。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"全自动笔试模式\",\n\t\t\t\"description\": \"独创的笔试模式，支持遥控截屏解题。用户只需一键操作，系统即可调用多个AI模型自动分析并解答各类在线笔试题目，范围覆盖编程、行测、图形推理、资料分析等。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Coding模式\",\n\t\t\t\"description\": \"在编程面试或技术笔试中，提供一键生成代码的功能，帮助用户快速解决算法和编程难题，并提供完善的思路分析。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"双设备互联\",\n\t\t\t\"description\": \"支持电脑和手机/平板等双端设备联动。用户可以在一台设备上进行面试或笔试，同时在另一台设备上实时接收AI生成的辅助信息，有效规避平台监控风险。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"求职者\",\n\t\t\t\"description\": \"为正在求职的各类人群，特别是应届毕业生和全球留学生，提供面试和笔试的实时AI辅助，帮助他们消除紧张感，干掉八股文，提升拿到Offer的成功率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"面试官\",\n\t\t\t\"description\": \"面试官也可以使用该工具，实时获得面试题提示或候选人回答分析，从而更流畅、高效地推进面试流程。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"各行业专业人士\",\n\t\t\t\"description\": \"适用于任何需要进行在线面试和笔试的岗位，包括但不限于程序员、产品经理、设计师、商业分析、金融、财会、人力资源等。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"极速响应\",\n\t\t\t\"description\": \"AI建议生成延迟低至800毫秒，语音传输延迟优化至35毫秒，确保在实时交流中获得无缝、流畅的辅助体验。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"全球网络加速\",\n\t\t\t\"description\": \"在全球五大洲部署了8个语音节点，为全球用户提供稳定、低延迟的加速服务，确保海外用户也能畅快使用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"隐私与安全\",\n\t\t\t\"description\": \"高度重视用户隐私，承诺不存储用户的任何面试记录，所有数据均存储在用户本地设备上，保障信息绝对安全。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"全平台支持\",\n\t\t\t\"description\": \"支持在电脑、手机、平板等任意设备上通过浏览器使用，并为Windows和macOS系统提供功能更强的桌面客户端。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"在线视频面试\",\n\t\t\t\"description\": \"求职者在电脑上进行视频面试，同时在旁边的手机或平板上登录Offerin AI。当面试官提问时，AI实时识别问题并在辅助设备上显示回答要点，求职者可参考作答。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"在线笔试/测评\",\n\t\t\t\"description\": \"参加在线笔试时，开启“笔试模式”。通过遥控截屏功能将题目发送给AI，AI自动进行分析和解答，并将答案返回给用户，适用于行测、编程题、资料分析等多种题型。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费额度\",\n\t\t\t\"description\": \"为新用户提供充裕的免费额度进行功能测试。用户还可以通过加入官方社群、邀请好友注册等方式获得更多免费积分甚至现金奖励。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"付费订阅\",\n\t\t\t\"description\": \"提供业内极具竞争力的定价方案。付费用户可享受更多高级功能和资源，官方宣称其双端互联等独家功能在同类产品中价格最低。（具体价格方案需访问官网价格页查看）\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"网页版快速使用\",\n\t\t\t\"description\": \"1. 在任何带有浏览器的设备（电脑/手机/平板）上访问Offerin AI官网。 2. 点击“开始使用”进入服务。 3. 根据当前是面试还是笔试，选择相应的功能模式开始使用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"客户端增强模式\",\n\t\t\t\"description\": \"1. 访问官网下载并安装适用于Windows 10+或Mac OS 13+的客户端。 2. 启动客户端并登录。 3. 若需使用双设备互联，请确保手机/平板也已准备就绪。 4. 在面试或笔试时启动相应功能。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"Offerin AI支持哪些岗位？\",\n\t\t\t\"description\": \"支持所有支持在线面试和笔试的岗位，包括但不限于：程序员、产品经理、设计师、商业分析、金融、财会、人力资源等任何岗位。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"我的面试数据是否安全？\",\n\t\t\t\"description\": \"绝对安全。官方承诺不会存储用户的任何面试记录，所有数据都保存在用户本地设备上。平台仅获取登录鉴权所必需的个人信息，隐私安全是其服务的重中之重。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"服务是否收费？\",\n\t\t\t\"description\": \"服务提供免费额度供新用户体验测试。同时提供多种付费方案，用户还可以通过邀请注册等方式获得额外奖励。官方宣称其定价在同类产品中是最低的。\"\n\t\t}\n\t]\n}",
