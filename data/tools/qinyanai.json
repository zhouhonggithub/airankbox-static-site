    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"文献管理与整合\",\n\t\t\t\"description\": \"提供云端存储，支持多层级文件夹、标签、星标评级等方式管理文献资料。可通过插件一键抓取网页、微信中的文献，并自动解析标题、作者等元数据。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI辅助阅读与理解\",\n\t\t\t\"description\": \"内置AI精读功能，可为PDF等文档生成摘要和思维导图。支持划线、高亮、批注等多种标记工具，并能在分屏视图下边读边写笔记。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"智能写作与引用\",\n\t\t\t\"description\": \"深度集成于Word和WPS，支持边写边搜，一键引用文献、图表、笔记等素材，并能自动生成符合超1万种期刊规范的参考文献。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI研究与分析\",\n\t\t\t\"description\": \"基于大语言模型，提供智能搜索、学术问答、文本翻译、内容改写和润色等功能，还能进行引文网络和关联文献的可视化分析。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"知识整理与构思\",\n\t\t\t\"description\": \"提供无限白板功能，用于整理各种资料和记录想法。摘录的笔记可以形成卡片集和回忆墙，帮助用户构建和回顾自己的知识体系。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"高校学生\",\n\t\t\t\"description\": \"在撰写课程论文或毕业设计时，用于高效管理和阅读大量文献，并利用AI辅助功能快速完成写作和格式排版。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"科研人员\",\n\t\t\t\"description\": \"在进行学术研究时，利用其AI分析和可视化功能探索前沿课题，并通过云端协作与团队成员共享资料和写作进度。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"知识工作者\",\n\t\t\t\"description\": \"需要处理和整合大量报告、资料的专业人士，可以使用它来构建个人知识库，并通过智能搜索快速找到所需信息。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"跨平台深度集成\",\n\t\t\t\"description\": \"提供网页版以及针对MS Office、WPS和Chrome的插件，实现了在写作环境中无缝搜索和引用资料的“边写边搜”体验。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"云端同步与团队协作\",\n\t\t\t\"description\": \"所有资料和笔记都存储在云端，支持多设备同步。企业版还提供团队协作工作台，方便团队成员共享资源、协同创作。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"强大的AI引擎\",\n\t\t\t\"description\": \"集成了大语言模型能力，不仅能处理文本（摘要、润色、翻译），还能进行深度分析（引文网络、文献溯源），提升科研效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"注重数据隐私\",\n\t\t\t\"description\": \"官方承诺用户数据默认仅自己可见，无商业广告和数据商业化，保障学术研究资料的私密性和安全性。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"论文选题与文献综述\",\n\t\t\t\"description\": \"研究初期，输入关键词进行AI学术搜索和问答，获取选题建议。利用可视化分析功能快速了解领域内的关键文献和研究脉络。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"撰写研究论文\",\n\t\t\t\"description\": \"在Word或WPS中打开沁言插件，边写作边搜索个人资料库或公共数据库，直接拖拽或点击引用内容，AI自动完成参考文献的格式化。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"深度阅读文献\",\n\t\t\t\"description\": \"将一批PDF文献上传后，使用AI精读功能快速生成每篇文献的摘要和思维导图，并对重点内容进行高亮和批注，笔记自动同步云端。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"团队协作研究\",\n\t\t\t\"description\": \"团队负责人创建共享空间，团队成员将收集的资料统一存入，共同在一个项目文档中写作，实时查看彼此的修改和评论。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费增值\",\n\t\t\t\"description\": \"提供包含2GB永久免费云存储空间的基础版本，满足个人用户的基本文献管理和写作需求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业版\",\n\t\t\t\"description\": \"面向企业和团队提供更强大的协作功能和解决方案，如智能编辑器、PDF解决方案、企业协作工作台等，具体价格需联系官方咨询。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"安装与快速上手\",\n\t\t\t\"description\": \"1. 根据需要从官网选择安装Word/WPS插件、Chrome插件或直接使用网页版；2. 注册并登录账号；3. 通过插件或网页上传/抓取您的第一份文献资料。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"在Word中引用文献\",\n\t\t\t\"description\": \"1. 在Word中打开沁言学术插件并登录；2. 在插件的搜索框中查找您资料库中的文献或笔记；3. 将光标置于需要插入引用的位置；4. 点击文献旁的“引用”按钮，即可插入文内引用并自动在文末生成参考文献。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"沁言学术支持哪些平台？\",\n\t\t\t\"description\": \"支持网页版（Chrome、Edge），并提供MS Office（macOS/Windows）、WPS（Windows）和Chrome浏览器的插件。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"我的研究数据安全吗？\",\n\t\t\t\"description\": \"官方承诺数据隐私，默认仅用户自己可见，且不进行商业化利用。同时提供授权码管理访问权限，保障数据安全。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"是否完全免费？\",\n\t\t\t\"description\": \"它采用免费增值的模式。个人用户可以免费使用基础功能和2GB云存储空间。对于有更高级需求或团队协作的用户，可以选择付费的企业版。\"\n\t\t}\n\t]\n}",
