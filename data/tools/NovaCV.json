    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"AI简历助手\",\n\t\t\t\"description\": \"用户输入基础信息后，NovaCV的AI助手能自动生成工作描述，通过智能润色引擎优化表达，确保内容精准且专业。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"智能纠错与翻译\",\n\t\t\t\"description\": \"实时智能纠错功能可避免低级错误，支持中英文智能翻译，助力海外求职，确保简历内容的准确性和专业性。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"专业模板与排版\",\n\t\t\t\"description\": \"提供20+精美模板，覆盖主流行业，支持一键套用和个性化调整，排版设计专业，符合招聘者喜好。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"在线编辑功能\",\n\t\t\t\"description\": \"支持在线编辑、多种模板选择、中英文切换、PDF导出等功能，让做简历更简单、更高效、更智能、更专业。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"API服务\",\n\t\t\t\"description\": \"提供API服务，支持简历智能检查、文本解析和模板生成等功能，满足企业和个人的多样化需求。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"应届毕业生\",\n\t\t\t\"description\": \"应届毕业生缺乏工作经验，对简历的格式和内容把握不准，AI简历助手可以根据用户输入的实习经历、项目经验等信息，自动生成专业的工作描述。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"跳槽求职者\",\n\t\t\t\"description\": \"求职者在跳槽或寻找新机会时，需要更新简历，AI助手可以根据最新的求职要求，帮助用户修改和优化简历内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"跨行业求职者\",\n\t\t\t\"description\": \"跨行业求职者需要重新定位自己的技能和经验，AI可以根据目标行业的要求，推荐相关的内容模块和关键词，帮助用户突出与新行业相关的技能和经验。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"HR和招聘人员\",\n\t\t\t\"description\": \"HR和招聘人员需要快速筛选和评估大量简历，AI可以帮助HR快速评估简历的完整性和竞争力，提供改进建议。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业内部管理者\",\n\t\t\t\"description\": \"企业需要统一管理员工的简历，方便在内部晋升或项目调配时使用，API服务可以满足企业内部简历管理的需求。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"10分钟快速创建\",\n\t\t\t\"description\": \"10分钟即可完成一份脱颖而出的求职简历，大幅提升简历制作效率，让用户快速获得更多面试机会。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"免费在线工具\",\n\t\t\t\"description\": \"完全免费的在线简历制作工具，无需下载安装，随时随地访问使用，降低用户使用门槛。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"智能AI技术\",\n\t\t\t\"description\": \"基于人工智能技术，集成了领先的AI功能，如智能简历助手、一键生成工作描述、AI润色引擎等。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"专业模板库\",\n\t\t\t\"description\": \"提供丰富的专业模板，覆盖主流行业，排版设计符合招聘者喜好，能帮助求职者在众多简历中脱颖而出。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"多语言支持\",\n\t\t\t\"description\": \"支持中英文切换和智能翻译，助力海外求职，满足不同语言环境下的简历制作需求。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"应届生求职\",\n\t\t\t\"description\": \"应届毕业生可以使用AI助手根据实习经历、项目经验等信息，自动生成专业的工作描述，突出个人优势。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"职场跳槽\",\n\t\t\t\"description\": \"有工作经验的求职者可以快速更新简历，AI助手根据最新求职要求帮助优化内容，提升竞争力。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"跨行业转型\",\n\t\t\t\"description\": \"跨行业求职者可以获得行业相关的关键词和内容模块推荐，重新定位技能和经验，适应新行业要求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"海外求职\",\n\t\t\t\"description\": \"支持中英文智能翻译，帮助用户制作符合海外招聘标准的简历，提升国际化求职成功率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业招聘管理\",\n\t\t\t\"description\": \"HR可以使用API服务快速评估简历质量，企业可以统一管理员工简历，提升招聘和管理效率。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费版\",\n\t\t\t\"description\": \"完全免费的在线简历制作工具，提供基础AI功能和模板，满足个人用户的基本简历制作需求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"API服务\",\n\t\t\t\"description\": \"为企业提供专业的API服务，支持简历智能检查、文本解析和模板生成，满足企业级需求。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"注册登录\",\n\t\t\t\"description\": \"1. 访问NovaCV官网：https://nova-cv.com/；2. 注册账号并登录；3. 进入简历制作界面。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"基础信息填写\",\n\t\t\t\"description\": \"1. 填写个人基本信息；2. 输入教育背景、工作经验等；3. 添加技能和项目经验。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI智能生成\",\n\t\t\t\"description\": \"1. 使用AI简历助手自动生成工作描述；2. 通过智能润色引擎优化表达；3. 实时智能纠错避免错误。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"模板选择与编辑\",\n\t\t\t\"description\": \"1. 从20+专业模板中选择合适的模板；2. 进行个性化调整和排版；3. 支持中英文切换。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"导出分享\",\n\t\t\t\"description\": \"1. 预览简历效果；2. 导出PDF格式；3. 保存或分享简历。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"NovaCV是什么？\",\n\t\t\t\"description\": \"NovaCV是基于人工智能技术的在线AI简历生成器，帮助用户快速制作专业、美观的求职简历，10分钟即可完成一份脱颖而出的简历。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"主要功能有哪些？\",\n\t\t\t\"description\": \"主要功能包括AI简历助手、智能纠错与翻译、专业模板与排版、在线编辑功能、API服务等，集成了领先的AI技术。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"是否免费使用？\",\n\t\t\t\"description\": \"是的，NovaCV是完全免费的在线简历制作工具，无需下载安装，随时随地访问使用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"支持哪些语言？\",\n\t\t\t\"description\": \"支持中英文切换和智能翻译，可以制作中英文简历，助力海外求职。\"\n\t\t}\n\t]\n}",
