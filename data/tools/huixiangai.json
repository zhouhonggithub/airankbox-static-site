    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"AI视频生成\",\n\t\t\t\"description\": \"基于AI技术帮助用户生成高质量的视频，让用户能轻松创建个性化的内容，支持各种类型视频的智能生成。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"灵感推荐\",\n\t\t\t\"description\": \"平台提供灵感推荐功能，帮助用户找到创意和灵感制作视频，为用户提供创作思路和参考案例。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"一键同款\",\n\t\t\t\"description\": \"用户基于一键操作快速生成与推荐或示例相似的视频，简化创作流程，提高创作效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"素材上传处理\",\n\t\t\t\"description\": \"支持用户上传图片等素材，AI自动分析并基于素材生成相应的视频内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"智能描述理解\",\n\t\t\t\"description\": \"用户输入视频内容描述，AI智能理解用户需求并生成符合描述的视频内容。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"社交媒体营销人员\",\n\t\t\t\"description\": \"生成吸引人的视频内容，用在社交媒体平台，如Instagram、TikTok等，提高品牌曝光度和用户参与度。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"在线教育工作者\",\n\t\t\t\"description\": \"制作教育视频和动画，用更直观的方式解释复杂的概念，适用在线课程、电子教材和教育网站。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业宣传人员\",\n\t\t\t\"description\": \"为企业制作宣传片、产品介绍视频或企业文化视频，用在官方网站、展会或商业会议，增强品牌形象。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"个人创作者\",\n\t\t\t\"description\": \"个人用户制作个人视频博客、短片或动画，分享个人故事，或在社交媒体上展示创意。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"游戏开发者\",\n\t\t\t\"description\": \"为游戏开发者提供工具，生成游戏内的角色、场景动画或宣传视频，适用虚拟现实(VR)和增强现实(AR)内容的创作。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"百度AI技术\",\n\t\t\t\"description\": \"基于百度强大的AI技术栈，确保视频生成的质量和智能化水平，提供安全、便捷的创作环境。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"简化创作流程\",\n\t\t\t\"description\": \"提供灵感推荐和一键生成功能，让每个人都能成为数字内容的创作者，无需专业技能即可制作生动、鲜活的作品。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"个性化内容创作\",\n\t\t\t\"description\": \"支持用户充分发挥创意，制作个性化的视频内容，满足不同用户的创作需求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"实时预览编辑\",\n\t\t\t\"description\": \"生成后可以预览内容，支持进一步的编辑和调整，确保最终作品符合用户期望。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"多平台分享\",\n\t\t\t\"description\": \"支持将生成的视频保存并分享到社交媒体或其他平台，便于内容传播。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"社交媒体营销\",\n\t\t\t\"description\": \"营销人员可以快速生成吸引人的视频内容，用于Instagram、TikTok等社交媒体平台，提升品牌曝光和用户参与度。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"在线教育制作\",\n\t\t\t\"description\": \"教育工作者可以制作教育视频和动画，用直观的方式解释复杂概念，适用于在线课程和电子教材。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业宣传制作\",\n\t\t\t\"description\": \"企业可以制作宣传片、产品介绍视频或企业文化视频，用于官方网站、展会或商业会议。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"个人娱乐创作\",\n\t\t\t\"description\": \"个人用户可以制作视频博客、短片或动画，分享个人故事或在社交媒体上展示创意。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"游戏内容开发\",\n\t\t\t\"description\": \"游戏开发者可以生成游戏内的角色、场景动画或宣传视频，适用于VR和AR内容创作。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费体验\",\n\t\t\t\"description\": \"提供基础功能体验，用户可以免费使用部分AI视频生成功能，了解平台能力。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"付费版本\",\n\t\t\t\"description\": \"提供更多高级功能和更高的使用额度，满足不同用户的使用需求。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"注册登录\",\n\t\t\t\"description\": \"1. 访问绘想平台官方网站：https://huixiang.baidu.com/；2. 创建一个账户并登录。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"选择功能\",\n\t\t\t\"description\": \"1. 根据需求选择相应的功能，比如视频生成；2. 浏览灵感推荐获取创作思路。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"上传素材\",\n\t\t\t\"description\": \"1. 上传想要生成视频的图片等素材；2. 在视频描述部分输入想要生成的视频内容描述。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"生成内容\",\n\t\t\t\"description\": \"1. 点击>开始生成< 按钮；2. 让平台根据输入生成视频；3. 等待AI处理完成。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"预览编辑\",\n\t\t\t\"description\": \"1. 生成后预览内容；2. 如果需要，进行进一步的编辑和调整；3. 确保效果符合预期。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"保存分享\",\n\t\t\t\"description\": \"1. 保存生成的视频；2. 根据需要分享到社交媒体或其他平台。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"绘想是什么平台？\",\n\t\t\t\"description\": \"绘想是百度推出的AI视频创作平台，基于AI技术帮助用户生成高质量的视频，让用户能轻松创建个性化的内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"主要功能有哪些？\",\n\t\t\t\"description\": \"主要功能包括视频生成、灵感推荐、一键同款等，提供灵感推荐和一键生成功能，简化创作流程。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"适用于哪些场景？\",\n\t\t\t\"description\": \"适用于社交媒体营销、在线教育、企业宣传、个人娱乐创作、游戏内容开发等多种场景。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"如何使用绘想？\",\n\t\t\t\"description\": \"注册登录后，选择功能、上传素材、输入描述、生成内容、预览编辑、保存分享，完成整个创作流程。\"\n\t\t}\n\t]\n}",
