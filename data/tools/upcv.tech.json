    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"聊天式简历生成\",\n\t\t\t\"description\": \"用户通过与AI进行类似聊天的问答互动，即可在3分钟内快速生成一份完整的简历初稿，无需手动填写繁琐的表格。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI生成工作经历\",\n\t\t\t\"description\": \"只需输入目标职位或行业，AI即可自动生成多条高质量、专业的工作经历描述，为用户提供内容参考。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI智能润色优化\",\n\t\t\t\"description\": \"提供一键优化功能，能将平淡的工作经历描述，智能升级为突出数据和亮点的专业话术，并能实时纠正错别字。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"精准匹配岗位JD\",\n\t\t\t\"description\": \"用户可以粘贴心仪岗位的职位描述（JD），AI会自动分析并优化简历中的关键词，使之与招聘要求高度对齐，提升简历通过筛选的概率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"拖拽式排版与导出\",\n\t\t\t\"description\": \"提供多款高颜值的简历模板，支持一键切换。用户可以通过拖拽模块自由排版，并能免费导出无水印的高清PDF文件。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"应届毕业生\",\n\t\t\t\"description\": \"缺乏简历写作经验，不知道如何将实习、社团活动等经历转化为有吸引力的简历内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"职场新人与跳槽者\",\n\t\t\t\"description\": \"希望快速、高效地针对不同职位制作多个版本的简历，或希望将现有工作成果包装得更专业，以寻求更好的职业发展。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"计划转行者\",\n\t\t\t\"description\": \"需要将过去行业的工作经验和技能，重新包装和表述，以符合新领域的要求，降低转行门槛。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"对话式交互体验\",\n\t\t\t\"description\": \"颠覆了传统的表格式简历填写方式，通过聊天交互引导用户提供信息，过程轻松自然，降低了简历制作的心理门槛。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"JD驱动的智能优化\",\n\t\t\t\"description\": \"核心亮点在于能够根据具体的职位描述（JD）来优化简历，使简历更具针对性，显著提高与目标岗位的匹配度。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"结果导向的内容生成\",\n\t\t\t\"description\": \"AI不仅是填充内容，更注重将经历转化为突出成果和数据的专业描述，帮助用户展现自身价值。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"免费且无水印\",\n\t\t\t\"description\": \"用户可以免费使用核心的AI生成、优化功能，并且导出的高清PDF简历不带任何水印，可以直接用于投递。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"应届生制作第一份简历\",\n\t\t\t\"description\": \"刚毕业的小白通过与AI对话，回答关于专业、实习和校内活动的问题，快速生成一份结构完整、内容专业的简历。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"为跳槽快速定制简历\",\n\t\t\t\"description\": \"有1-3年工作经验的职场人，看到心仪的公司发布了新职位，复制其JD到UP简历，AI自动帮忙优化简历关键词，10分钟内生成一份高度匹配的定制简历并投递。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"运营岗转产品岗\",\n\t\t\t\"description\": \"一位运营人员希望转为产品经理，利用AI的润色和岗位匹配功能，将原来的用户增长、活动策划等经历，重写为体现产品思维和数据分析能力的话术。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费增值\",\n\t\t\t\"description\": \"核心功能（如AI生成、优化、多模板选择、无水印导出PDF）均免费提供，满足大部分用户的求职需求。可能存在付费的高级功能或服务。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"三分钟生成简历\",\n\t\t\t\"description\": \"1. 访问UP简历官网并登录；2. AI会主动提问，引导用户输入求职意向、工作经历等基本信息；3. AI根据回答自动生成简历初稿。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"针对性优化简历\",\n\t\t\t\"description\": \"1. 在生成的简历基础上，点击“AI优化”润色描述；2. 粘贴目标岗位的JD，使用“岗位匹配”功能；3. AI会自动对齐关键词并优化；4. 选择心仪的模板，导出PDF即可。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"使用UP简历需要付费吗？\",\n\t\t\t\"description\": \"基本不需要。UP简历采用免费增值模式，其核心的简历生成、AI优化和无水印导出功能都是免费的。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"我不会写工作经历怎么办？\",\n\t\t\t\"description\": \"这是UP简历的核心优势。你只需输入职位名称，AI就能为你生成多条高质量的工作经历描述供你选择和修改。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"如何让我的简历更匹配心仪的公司？\",\n\t\t\t\"description\": \"你可以直接将该公司的职位描述（JD）粘贴到UP简历的“岗位匹配”功能中，AI会自动帮你分析并优化简历，使其更符合招聘要求。\"\n\t\t}\n\t]\n}",
