    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"AI 图像生成\",\n\t\t\t\"description\": \"用户可以通过文本描述或参考图片，利用 AI 模型生成全新的、高质量的图像作品。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"背景处理\",\n\t\t\t\"description\": \"提供一键移除图片背景和替换背景的功能，能够快速提取主体或更换为指定的颜色或新图像背景，适用于产品图、证件照等场景。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"图像修复与编辑\",\n\t\t\t\"description\": \"具备智能修复（Inpaint）功能，可以去除图片中的多余物体或修复瑕疵。同时提供橡皮擦（Eraser）工具进行精细修改。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"画质增强与扩展\",\n\t\t\t\"description\": \"支持图像无损放大（Upscale），提升低分辨率图片的清晰度；同时具备图像扩展（Expand）功能，能够智能地扩展图片边界，补充画面内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"图像风格化\",\n\t\t\t\"description\": \"可以将上传的图片转换为多种不同的艺术风格，如油画、水彩等，满足用户的创意设计需求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"图像内容重做\",\n\t\t\t\"description\": \"提供重做（Redux）功能，使用智能视觉转换技术重新构建和定义图像内容，为创作提供更多可能性。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"设计师与创意工作者\",\n\t\t\t\"description\": \"设计师和创意人士可以利用Kira的多种AI图像功能快速生成和编辑素材，激发创作灵感，提升工作效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"电商运营者\",\n\t\t\t\"description\": \"电商卖家可以使用背景移除和替换功能，快速制作专业的商品展示图，提升产品吸引力，而无需复杂的P图技巧。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"社交媒体创作者\",\n\t\t\t\"description\": \"内容创作者可以利用AI生成和风格化功能，快速产出独特、吸睛的图片素材，丰富其社交媒体内容。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"摄影师\",\n\t\t\t\"description\": \"摄影师可以利用画质增强和修复功能对照片进行后期处理，提升作品质量或修复老照片。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"多功能集成\",\n\t\t\t\"description\": \"集成了从AI生成、背景处理到画质增强、风格化等多种实用功能，提供一站式的AI图像解决方案。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"操作便捷\",\n\t\t\t\"description\": \"界面简洁直观，大部分功能支持一键式操作，用户无需专业技能即可快速上手并获得高质量的成果。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"高质量输出\",\n\t\t\t\"description\": \"基于先进的AI模型，无论是生成还是编辑，都能确保输出的图片具有较高的清晰度和视觉效果。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"创意社区\",\n\t\t\t\"description\": \"拥有一个作品画廊（Gallery），用户可以在这里浏览他人的创意作品，获取灵感，也可以分享自己的创作。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"电商产品图制作\",\n\t\t\t\"description\": \"上传产品图片，一键移除杂乱背景，替换为纯色或场景图，生成符合平台要求的专业商品图。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"老照片修复\",\n\t\t\t\"description\": \"上传有划痕或模糊的老照片，使用修复（Inpaint）和画质增强（Upscale）功能，让珍贵的回忆焕然一新。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"创意海报设计\",\n\t\t\t\"description\": \"输入一段创意的文字描述，选择艺术风格，由AI生成一张独特的海报主图，再进行细节调整和组合。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"证件照制作\",\n\t\t\t\"description\": \"将生活照上传，使用背景替换功能快速更换为蓝、白、红底，制作出符合规格的证件照。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费增值\",\n\t\t\t\"description\": \"网站提供免费增值服务，用户可以免费体验基础功能，但具体免费额度未明确说明，付费可解锁更多积分和高级功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"基础套餐\",\n\t\t\t\"description\": \"每月 $9.99，包含 1000 积分，可用于各项AI功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"专业套餐\",\n\t\t\t\"description\": \"每月 $19.99，包含 2000 积分，并可使用更多高级功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"最大套餐\",\n\t\t\t\"description\": \"每月 $59.99，包含 6000 积分，并可使用更多高级功能。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"使用AI生成图片\",\n\t\t\t\"description\": \"1. 访问Kira官网并登录；2. 选择“AI生成”功能；3. 在文本框中输入详细的画面描述；4. 根据需要调整风格等参数；5. 点击生成按钮，等待片刻即可获得图像。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"移除图片背景\",\n\t\t\t\"description\": \"1. 访问Kira官网并登录；2. 选择“移除背景”功能；3. 上传需要处理的图片；4. AI将自动处理并呈现移除背景后的效果；5. 下载处理好的透明背景图片。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"Kira支持哪些图片格式？\",\n\t\t\t\"description\": \"根据第三方介绍，Kira支持常见的图片格式，如JPG、PNG等，方便用户上传和处理。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"生成的图片可以商用吗？\",\n\t\t\t\"description\": \"一般情况下，付费套餐会提供商业使用许可，但具体条款建议查阅官网的法律（Legal）或服务条款部分以获取最准确的信息。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"使用各项功能如何消耗积分？\",\n\t\t\t\"description\": \"定价计划以积分为核心，但官方网站和第三方评测均未提供各项功能（如生成、修复、放大等）具体消耗的积分数量，用户需在实际使用中了解。\"\n\t\t}\n\t]\n}",
