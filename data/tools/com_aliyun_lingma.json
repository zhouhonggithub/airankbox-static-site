    "htmlContent": "{\"title\":\"通义灵码\",\"url\":\"https://lingma.aliyun.com/\",\"functions\":[{\"name\":\"编程智能体协同\",\"description\":\"具备自主决策、环境感知、工具使用等能力，使用工程检索、文件编辑、终端等工具，进行工程级多文件修改，端到端完成编码任务。\"},{\"name\":\"行间代码生成\",\"description\":\"支持根据当前代码文件及跨文件上下文，生成行级/函数级代码，提供沉浸式编码体验，秒级生成速度。\"},{\"name\":\"研发智能问答\",\"description\":\"基于海量研发文档、产品文档、通用研发知识和阿里云服务文档训练，为开发者答疑解惑。\"},{\"name\":\"代码解释分析\",\"description\":\"支持200多种语言识别，选中代码后自动识别编程语言并生成代码解释及可视化流程图。\"},{\"name\":\"问题智能排查\",\"description\":\"结合工程内代码和环境信息，快速排查编码问题、编译报错、运行报错等，提供解决方案。\"},{\"name\":\"企业个性化扩展\",\"description\":\"支持企业私域知识库，提供自定义扩展能力，企业级账号管理和安全审计功能。\"}],\"roles\":[{\"name\":\"软件开发者\",\"description\":\"提供全方位编码辅助，从代码生成到问题排查，显著提升开发效率和代码质量。\"},{\"name\":\"数据分析师\",\"description\":\"在数据处理和分析任务中提供编程支持，帮助快速实现数据处理逻辑。\"},{\"name\":\"技术决策者\",\"description\":\"通过智能问答和代码分析，协助进行技术方案评估和决策制定。\"}],\"features\":[{\"name\":\"国际认可\",\"description\":\"阿里云是唯一进入Gartner AI代码助手挑战者象限的中国厂商，通义灵码获信通院最高等级认证。\"},{\"name\":\"安全可靠\",\"description\":\"全链路加密传输，绝不存储用户代码，不用于二次训练，仅使用开源合规代码训练模型。\"},{\"name\":\"企业级功能\",\"description\":\"支持企业知识库集成、权限管理、统计报表、审计日志等企业级管理功能。\"}],\"scenarios\":[{\"name\":\"大型项目开发\",\"description\":\"在复杂企业级项目中，编程智能体能够自动感知工程框架和技术栈，跨多文件进行智能修改和优化。\"},{\"name\":\"团队协作开发\",\"description\":\"结合企业知识库，确保团队开发规范一致性，提升团队整体开发效率和代码质量。\"},{\"name\":\"技术问题排查\",\"description\":\"当遇到复杂技术问题时，通过智能问答和代码分析快速定位问题根源并提供解决方案。\"}],\"pricing_plan\":[{\"name\":\"个人基础版 (免费)\",\"description\":\"代码智能补全、注释生成代码、跨文件感知、研发智能问答、多文件修改、编程智能体(限50轮次/月)等功能。\"},{\"name\":\"个人专业版 (限时免费)\",\"description\":\"包含基础版所有功能，无编程智能体对话次数限制，提供更强大的AI辅助能力。\"},{\"name\":\"企业标准版 (79元/人/月)\",\"description\":\"10人起购，30天免费试用。包含企业代码库生成增强、知识库问答、权限管理、统计报表等企业功能。\"},{\"name\":\"企业专属版 (159元/人/月)\",\"description\":\"100人起购。包含多组织管理、专属VPC部署、IP白名单、专有网络访问等高级企业功能。\"}],\"usage\":[{\"name\":\"IDE插件使用\",\"description\":\"支持Visual Studio Code、Visual Studio、JetBrains IDEs等主流编程工具，下载对应插件后即可开始使用。提供实时代码补全、智能问答、多文件编辑等功能。支持Java、Python、Go、TypeScript、JavaScript、C/C++等200种编程语言。\"},{\"name\":\"Lingma IDE使用\",\"description\":\"下载专门的Lingma IDE，享受为AI编程优化的完整开发环境。通过编程智能体模式，可以描述需求让AI自动完成复杂的编码任务。支持终端命令执行、工程自动感知等高级功能，实现真正的人机协同编程。\"}]}",
