    "htmlContent": "{\n  \"title\": \"豆包\",\n  \"url\": \"https://www.doubao.com/chat/\",\n  \"functions\": [\n    {\n      \"name\": \"智能对话交互\",\n      \"description\": \"基于豆包大模型的自然语言对话能力，支持多轮对话、上下文理解，提供准确且富有情感的回复。\"\n    },\n    {\n      \"name\": \"AI写作助手\",\n      \"description\": \"提供文案创作、内容改写、学术写作、邮件撰写等多种写作辅助功能，支持不同风格和场景。\"\n    },\n    {\n      \"name\": \"AI图像生成\",\n      \"description\": \"基于文本描述生成高质量图像，支持多种艺术风格，包括写实、动漫、水彩等创作风格。\"\n    },\n    {\n      \"name\": \"智能搜索功能\",\n      \"description\": \"结合AI理解能力的联网搜索，提供准确的信息检索和内容整合，支持实时信息获取。\"\n    },\n    {\n      \"name\": \"文档处理分析\",\n      \"description\": \"支持PDF、Word、PPT等多种格式文档的上传和分析，提供文档摘要和问答功能。\"\n    },\n    {\n      \"name\": \"语音交互功能\",\n      \"description\": \"支持语音输入和语音输出，提供自然流畅的语音对话体验，支持多种音色选择。\"\n    },\n    {\n      \"name\": \"AI智能体创建\",\n      \"description\": \"用户可以创建个性化AI智能体，自定义角色特征、专业领域和对话风格。\"\n    },\n    {\n      \"name\": \"多模态内容生成\",\n      \"description\": \"支持文本、图像、音乐等多种内容格式的AI生成，满足不同创作需求。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"学生群体\",\n      \"description\": \"为学生提供学习辅导、作业帮助、论文写作、知识问答等教育支持服务。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"帮助创作者进行文案创作、创意构思、内容优化，提供写作灵感和素材支持。\"\n    },\n    {\n      \"name\": \"办公人员\",\n      \"description\": \"协助处理工作文档、邮件撰写、报告生成、数据分析等办公场景需求。\"\n    },\n    {\n      \"name\": \"开发者\",\n      \"description\": \"提供代码生成、调试协助、技术文档编写、编程学习等开发支持。\"\n    },\n    {\n      \"name\": \"营销人员\",\n      \"description\": \"协助营销文案创作、广告创意生成、市场分析、社媒内容制作等营销工作。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"字节跳动出品\",\n      \"description\": \"由字节跳动公司开发，基于自研豆包大模型，技术实力雄厚，产品稳定可靠。\"\n    },\n    {\n      \"name\": \"完全免费使用\",\n      \"description\": \"目前提供完全免费的AI服务，无使用次数限制，用户可以无障碍体验各项功能。\"\n    },\n    {\n      \"name\": \"多端支持\",\n      \"description\": \"支持网页版、手机APP、桌面客户端、浏览器插件等多种使用方式。\"\n    },\n    {\n      \"name\": \"智能体生态\",\n      \"description\": \"拥有丰富的AI智能体生态，用户可以使用或创建专业领域的智能体。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"日常学习辅导\",\n      \"description\": \"学生可以向豆包提问各种学科问题，获得详细的解答和学习指导。豆包能够根据不同学习阶段提供适合的解释和例子，帮助理解复杂概念，还能协助完成作业和准备考试。\"\n    },\n    {\n      \"name\": \"专业内容创作\",\n      \"description\": \"内容创作者可以利用豆包进行文案创作、文章写作、创意构思等工作。豆包能够根据不同平台特性和目标受众，生成符合要求的高质量内容，大大提升创作效率。\"\n    },\n    {\n      \"name\": \"办公效率提升\",\n      \"description\": \"办公人员可以使用豆包处理日常工作任务，如邮件撰写、报告生成、文档总结、数据分析等。豆包的文档处理能力能够快速提取关键信息，节省大量工作时间。\"\n    },\n    {\n      \"name\": \"编程开发辅助\",\n      \"description\": \"开发者可以利用豆包进行代码生成、bug调试、技术文档编写等开发工作。豆包支持多种编程语言，能够提供代码解释、优化建议和最佳实践指导。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"完全免费\",\n      \"description\": \"豆包目前提供完全免费的服务，包括AI对话、图像生成、文档处理、智能体使用等所有功能都可以免费体验，无需付费订阅。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"直接访问 https://www.doubao.com/chat/ 即可开始使用。无需注册也可以体验基本功能，注册账号后可以保存对话历史，创建个人智能体，享受更完整的服务体验。操作简单直观，支持文本输入、语音输入、文件上传等多种交互方式。\"\n    },\n    {\n      \"name\": \"手机APP下载\",\n      \"description\": \"在苹果App Store或各大安卓应用商店搜索'豆包'即可下载安装。手机版功能完整，支持语音对话、拍照识图、智能体使用等功能。APP界面针对移动端优化，支持多种输入方式，随时随地都能使用AI助手服务。\"\n    },\n    {\n      \"name\": \"桌面客户端\",\n      \"description\": \"豆包提供Windows和Mac桌面客户端，可以从官网下载安装。桌面版具有更强大的文档处理能力，支持大文件上传和批量处理，还提供浏览器插件功能，能够与其他办公软件无缝集成，大幅提升工作效率。\"\n    }\n  ]\n}",
