    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"AI一键生成多类图表\",\n      \"description\": \"支持上传文本、PDF、PPT、Word、图片、网页等多种内容，AI自动解析并生成思维导图、流程图、表格、看板等多种可视化图表。\"\n    },\n    {\n      \"name\": \"自然语言对话生成图表\",\n      \"description\": \"用户只需用自然语言描述需求，AI即可快速生成相应图表，无需绘图经验。\"\n    },\n    {\n      \"name\": \"多轮对话与上下文优化\",\n      \"description\": \"支持多轮对话，AI可记忆上下文，持续优化和完善图表内容。\"\n    },\n    {\n      \"name\": \"图表智能转换\",\n      \"description\": \"支持不同图表类型间一键智能转换，如思维导图转流程图、卡片、表格等，无需重新绘制。\"\n    },\n    {\n      \"name\": \"多格式导入导出\",\n      \"description\": \"支持导入PDF、PPT、Word、TXT、图片、网页等，导出为PDF、图片、PPT等多种格式，便于分享和展示。\"\n    },\n    {\n      \"name\": \"团队实时协作\",\n      \"description\": \"支持多人实时在线编辑、评论和反馈，提升团队协作效率。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"个人用户\",\n      \"description\": \"用于读书笔记、知识整理、旅行计划、健康管理、目标设定等个人场景。\"\n    },\n    {\n      \"name\": \"学生/教师\",\n      \"description\": \"快速生成思维导图、流程图等，辅助教学、知识梳理和学习笔记。\"\n    },\n    {\n      \"name\": \"产品/项目经理\",\n      \"description\": \"用于项目进度展示、资源分配、目标拆解、系统架构图等。\"\n    },\n    {\n      \"name\": \"开发者/设计师\",\n      \"description\": \"绘制系统架构图、ER图、UML图、设计素材等，提升开发与设计效率。\"\n    },\n    {\n      \"name\": \"企业团队\",\n      \"description\": \"支持企业级私有化部署，保障数据安全，实现高效团队协作。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"多类型图表支持\",\n      \"description\": \"支持思维导图、流程图、组织结构图、甘特图、卡片、看板等多种类型。\"\n    },\n    {\n      \"name\": \"专业模板库\",\n      \"description\": \"内置1000+专业模板，覆盖各行业场景，灵感丰富。\"\n    },\n    {\n      \"name\": \"无限画布自由创作\",\n      \"description\": \"提供无限画布，用户可自由发挥创意绘制精美图形。\"\n    },\n    {\n      \"name\": \"智能协作与评论\",\n      \"description\": \"团队成员可在同一画布上实时编辑、评论和反馈，内容实时同步。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"知识梳理与学习笔记\",\n      \"description\": \"学生和教师可快速生成思维导图、流程图，梳理知识点，制作学习笔记。\"\n    },\n    {\n      \"name\": \"项目管理与进度展示\",\n      \"description\": \"项目经理可用流程图、甘特图展示项目进度和资源分配。\"\n    },\n    {\n      \"name\": \"系统架构与开发设计\",\n      \"description\": \"开发者可绘制系统架构图、ER图、UML图，辅助软件开发。\"\n    },\n    {\n      \"name\": \"团队头脑风暴与协作\",\n      \"description\": \"团队成员可在同一画布上协作，实时交流和完善方案。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"个人版半年\",\n      \"description\": \"¥69/半年（原价¥119），含80000 AI点数，不限文件数量、历史版本，超清无水印导出，7x12小时客服支持。\"\n    },\n    {\n      \"name\": \"个人版包年\",\n      \"description\": \"¥89/年（原价¥199），含150000 AI点数，不限文件数量、历史版本，超清无水印导出，7x12小时客服支持。\"\n    },\n    {\n      \"name\": \"个人版终身\",\n      \"description\": \"¥399（原价¥799），一次付费终身使用，含1000000 AI点数，不限文件数量、历史版本，超清无水印导出，7x12小时客服支持。\"\n    },\n    {\n      \"name\": \"AI无限包\",\n      \"description\": \"半年包¥9，年包¥19，终身包¥99，订购后在版本有效期内AI点数无限使用。\"\n    },\n    {\n      \"name\": \"企业定制/私有化部署\",\n      \"description\": \"支持企业级私有化部署，独立运行，数据更安全，需联系官方咨询定价。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"AI生成图表流程\",\n      \"description\": \"1. 访问Fluig官网并注册/登录；2. 上传文件或输入需求；3. AI自动解析并生成图表；4. 可多轮对话优化内容；5. 导出或一键分享。\"\n    },\n    {\n      \"name\": \"团队协作流程\",\n      \"description\": \"1. 创建团队或邀请成员加入；2. 在同一画布上实时编辑、评论和反馈；3. 内容实时同步，提升协作效率。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"需要绘图经验吗？\",\n      \"description\": \"不需要，用户只需用自然语言描述需求，AI即可自动生成各类图表。\"\n    },\n    {\n      \"name\": \"支持哪些文件格式？\",\n      \"description\": \"支持导入PDF、PPT、Word、TXT、图片、网页等，导出为PDF、图片、PPT等多种格式。\"\n    },\n    {\n      \"name\": \"生成的图表可以导出吗？\",\n      \"description\": \"可以，支持导出为PDF、PNG、JPG、PPT等多种格式。\"\n    },\n    {\n      \"name\": \"是否支持团队协作？\",\n      \"description\": \"支持，团队成员可实时在线协作、评论和反馈。\"\n    },\n    {\n      \"name\": \"有企业私有化部署吗？\",\n      \"description\": \"支持企业级私有化部署，保障数据安全，需联系官方咨询。\"\n    }\n  ]\n}",
