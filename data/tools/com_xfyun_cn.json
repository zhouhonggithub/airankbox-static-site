    "htmlContent": "{\n  \"title\": \"讯飞星火\",\n  \"url\": \"https://xinghuo.xfyun.cn/\",\n  \"functions\": [\n    {\n      \"name\": \"多模态理解\",\n      \"description\": \"支持文本、图像、语音等多种模态的输入理解，能够分析图片内容、识别语音指令。\"\n    },\n    {\n      \"name\": \"代码生成助手\",\n      \"description\": \"iFlyCode插件提供强大的编程辅助，支持代码生成、补全、解释、纠错和单元测试等功能。\"\n    },\n    {\n      \"name\": \"语音交互\",\n      \"description\": \"星火语伴提供自然的语音对话体验，支持多语言语音识别和合成，适合口语练习。\"\n    },\n    {\n      \"name\": \"虚拟人合成\",\n      \"description\": \"讯飞智作2.0可生成逼真的虚拟人视频，支持文本转语音、表情动作同步等功能。\"\n    },\n    {\n      \"name\": \"办公辅助\",\n      \"description\": \"提供PPT生成、简历制作、文档问答等办公场景的智能化解决方案。\"\n    },\n    {\n      \"name\": \"智能搜索\",\n      \"description\": \"结合实时搜索能力，提供准确的信息查询和分析服务。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"开发者\",\n      \"description\": \"编程辅助、代码优化、技术问题解决，通过iFlyCode插件提升开发效率。\"\n    },\n    {\n      \"name\": \"教育工作者\",\n      \"description\": \"课件制作、教学辅助、学生答疑，创新教学方式和内容呈现。\"\n    },\n    {\n      \"name\": \"商务人士\",\n      \"description\": \"报告生成、文档处理、会议记录，提升办公效率和工作质量。\"\n    },\n    {\n      \"name\": \"学生\",\n      \"description\": \"学习辅导、作业帮助、语言练习，全方位的学习支持服务。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"视频制作、文案创作、创意生成，丰富内容创作工具和素材。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"国产自主\",\n      \"description\": \"科大讯飞自主研发的认知智能大模型，体现中国AI技术实力和创新能力。\"\n    },\n    {\n      \"name\": \"语音技术领先\",\n      \"description\": \"基于科大讯飞20多年的语音技术积累，在语音识别和合成方面具有技术优势。\"\n    },\n    {\n      \"name\": \"行业应用丰富\",\n      \"description\": \"在教育、医疗、司法、工业等多个行业有深度应用和解决方案。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"编程开发\",\n      \"description\": \"\\\"用Python写一个数据爬虫程序\\\" - 通过iFlyCode快速生成完整代码，包括异常处理和优化建议。\"\n    },\n    {\n      \"name\": \"教学辅助\",\n      \"description\": \"\\\"制作一份关于人工智能的教学PPT\\\" - 自动生成结构化课件，包含图表和互动元素。\"\n    },\n    {\n      \"name\": \"语言学习\",\n      \"description\": \"\\\"练习英语口语对话\\\" - 通过星火语伴进行实时语音交互，纠正发音和语法错误。\"\n    },\n    {\n      \"name\": \"内容创作\",\n      \"description\": \"\\\"制作一个产品介绍视频\\\" - 使用虚拟人合成功能创建专业的解说视频。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费试用\",\n      \"description\": \"新用户免费体验基础功能，包括文本对话、简单图像识别等服务。\"\n    },\n    {\n      \"name\": \"个人版\",\n      \"description\": \"面向个人用户的付费版本，提供更多功能限额和高级特性。\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"面向企业用户的定制化解决方案，包含私有化部署和专业技术支持。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"访问https://xinghuo.xfyun.cn注册使用，支持文本对话、图像上传、文档分析等功能。提供丰富的助手模板，用户可根据需求选择不同的专业助手进行交互。\"\n    },\n    {\n      \"name\": \"移动应用\",\n      \"description\": \"下载讯飞星火APP，体验移动端的语音交互、拍照识别、实时翻译等功能。支持离线语音识别，在网络不佳的环境下也能正常使用基础功能。\"\n    },\n    {\n      \"name\": \"专业插件\",\n      \"description\": \"安装iFlyCode、星火语伴等专业插件，在特定场景下获得更专业的AI助手服务。插件与主应用深度集成，提供无缝的用户体验和专业功能支持。\"\n    }\n  ]\n}",
