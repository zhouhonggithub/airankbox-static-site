    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"文本生成音乐\",\n      \"description\": \"用户只需输入文本或歌词，MakeSong 即可自动生成与之匹配的音乐。该功能利用先进的自然语言处理和音乐生成算法，确保生成的音乐与文本内容高度契合。\"\n    },\n    {\n      \"name\": \"多风格支持\",\n      \"description\": \"MakeSong 支持多种音乐风格，包括流行、摇滚、电子、古典等。用户可以根据需求选择不同的风格，生成符合场景的音乐作品。\"\n    },\n    {\n      \"name\": \"歌词适配\",\n      \"description\": \"工具能够智能分析歌词的情感和节奏，自动生成与之匹配的旋律和编曲。这一功能特别适合音乐创作者快速实现创作灵感。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"内容创作者可以使用 MakeSong 为视频、播客或社交媒体内容生成独特的背景音乐，提升内容的吸引力和专业性。\"\n    },\n    {\n      \"name\": \"营销人\",\n      \"description\": \"营销人可以利用 MakeSong 快速生成广告或宣传视频的背景音乐，节省制作成本和时间，同时确保音乐与品牌调性一致。\"\n    },\n    {\n      \"name\": \"设计师\",\n      \"description\": \"设计师可以通过 MakeSong 为多媒体项目定制音乐，增强用户体验和项目的整体表现力。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"高质量生成\",\n      \"description\": \"MakeSong 采用先进的 AI 技术，生成的音乐质量高，接近专业音乐制作水平。\"\n    },\n    {\n      \"name\": \"快速生成\",\n      \"description\": \"用户只需输入文本或歌词，即可在几秒钟内生成完整的音乐作品，大大提升了创作效率。\"\n    },\n    {\n      \"name\": \"多语言支持\",\n      \"description\": \"工具支持多种语言的文本输入，能够为全球用户提供音乐生成服务。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"社交媒体内容制作\",\n      \"description\": \"用户输入一段描述或歌词，选择适合的音乐风格，生成背景音乐后直接下载并添加到视频中，提升内容的吸引力。\"\n    },\n    {\n      \"name\": \"广告音乐制作\",\n      \"description\": \"营销团队输入广告文案，选择符合品牌调性的音乐风格，生成专属广告音乐，用于视频或音频广告。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费版\",\n      \"description\": \"每个免费账户可以生成 10首免费歌曲，可用于任何商业用途。\"\n    },\n    {\n      \"name\": \"专业版\",\n      \"description\": \"每月 $9.99，可生成 20 首歌曲，每首歌曲长度限制为 3 分钟，支持所有音乐风格和高清音质下载。\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"每月 $29.99，无限生成歌曲，无长度限制，支持所有音乐风格、高清音质下载及商业使用权。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"文本生成音乐\",\n      \"description\": \"1. 访问 MakeSong 官网；2. 在输入框中输入文本或歌词；3. 选择音乐风格；4. 点击生成按钮；5. 下载生成的音乐文件。\"\n    },\n    {\n      \"name\": \"歌词适配生成\",\n      \"description\": \"1. 访问 MakeSong 官网；2. 在输入框中粘贴歌词；3. 选择情感和节奏偏好；4. 点击生成按钮；5. 下载生成的音乐文件。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"生成的音乐可以商用吗？\",\n      \"description\": \"免费版生成的音乐仅限个人使用，专业版和企业版生成的音乐可用于商业用途，具体权限请参考官网的使用条款。\"\n    },\n    {\n      \"name\": \"支持哪些语言输入？\",\n      \"description\": \"MakeSong 支持英语、中文、西班牙语等多种语言的文本输入，能够根据语言特点生成相应的音乐。\"\n    },\n    {\n      \"name\": \"生成的音乐可以编辑吗？\",\n      \"description\": \"目前 MakeSong 生成的音乐不支持直接编辑，但用户可以调整输入文本或歌词重新生成音乐。\"\n    }\n  ]\n}",
