    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"笔试模式\",\n      \"description\": \"通过快捷键截屏生成编程题、选择题等答案，支持多种题型和主流编程语言，支持多次debug。\"\n    },\n    {\n      \"name\": \"面试模式\",\n      \"description\": \"实时识别面试官语音问题，自动生成结构化回答建议，适用于技术面和行为面。\"\n    },\n    {\n      \"name\": \"完美隐蔽\",\n      \"description\": \"在主流面试/笔试平台屏幕共享时不可见，规避反作弊检测，100%隐身。\"\n    },\n    {\n      \"name\": \"多语言支持\",\n      \"description\": \"支持10种主流编程语言和中英文输入输出。\"\n    },\n    {\n      \"name\": \"高级功能\",\n      \"description\": \"支持SQL代码生成与分析、选题辅助解答、高级debug模式、自由选择AI模型、语音交互等。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"求职者/面试者\",\n      \"description\": \"提升笔试、面试效率，获得高质量AI辅助答案和建议，增强自信应对技术与行为面。\"\n    },\n    {\n      \"name\": \"学生/实习生\",\n      \"description\": \"用于模拟练习、准备校招/实习面试，提升答题和面试表现。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"支持主流平台\",\n      \"description\": \"兼容Chrome、Edge、腾讯会议、Zoom、Google Meet、LeetCode、HackerRank、CoderPad等。\"\n    },\n    {\n      \"name\": \"高准确率AI模型\",\n      \"description\": \"旗舰版支持顶级AI模型（如GPT-4.1、Claude 4等），最高99%准确率。\"\n    },\n    {\n      \"name\": \"快捷键操作\",\n      \"description\": \"多种快捷键便捷操作，如截屏、生成答案、重置、窗口移动等。\"\n    },\n    {\n      \"name\": \"7x24客户支持\",\n      \"description\": \"提供全天候技术支持和售后服务。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"笔试答题辅助\",\n      \"description\": \"在LeetCode、牛客网等平台，截屏生成编程题、选择题等答案，提升答题效率。\"\n    },\n    {\n      \"name\": \"技术面试支持\",\n      \"description\": \"开启语音模式，实时获取算法、数据结构等技术问题的AI建议。\"\n    },\n    {\n      \"name\": \"行为面试指导\",\n      \"description\": \"结构化生成行为面试问题的高质量回答建议，帮助面试者快速组织语言。\"\n    },\n    {\n      \"name\": \"模拟练习\",\n      \"description\": \"通过截屏或语音模式，模拟真实笔试/面试场景，提升实战能力。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费版\",\n      \"description\": \"支持10种主流编程语言，每日3次免费AI问答，适合轻度使用者。\"\n    },\n    {\n      \"name\": \"专业版\",\n      \"description\": \"¥49/周，¥99/月，无限AI问答，90%准确率，支持高级AI模型（如GPT-4o、Gemini 2.0 Flash）、高级debug、SQL代码生成与分析、选题辅助、高级语音模式（每周2小时），3天免费试用。\"\n    },\n    {\n      \"name\": \"旗舰版\",\n      \"description\": \"¥99/周，¥199/月，无限AI问答，99%准确率，无限制使用顶级AI模型（如GPT-4.1、Claude 4等）、自由选择AI模型、高级debug、SQL代码生成与分析、选题辅助、高级语音模式（每周10小时）。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"笔试模式使用流程\",\n      \"description\": \"1. 下载并安装Gank Interview；2. 注册并登录；3. 打开笔试平台，选择“笔试模式”；4. 使用快捷键截屏（Cmd/Ctrl+H）；5. 使用快捷键生成答案（Cmd/Ctrl+回车）；6. 复制答案粘贴到平台。\"\n    },\n    {\n      \"name\": \"面试模式使用流程\",\n      \"description\": \"1. 打开面试平台（如Zoom、腾讯会议等）；2. 选择“面试模式”；3. 开始录音或语音识别；4. 查看AI生成的回答建议，调整后作答。\"\n    }\n  ],\n  \"questions\": [\n    \n    {\n      \"name\": \"如何保证隐蔽性？\",\n      \"description\": \"Gank Interview在主流平台屏幕共享时不可见，规避反作弊检测，100%隐身。\"\n    },\n    {\n      \"name\": \"可以退款吗？\",\n      \"description\": \"订购后3天内无条件退款，超出3天如有合理使用问题可联系客服处理。\"\n    },\n    {\n      \"name\": \"如何联系客服？\",\n      \"description\": \"可邮件至support@mail.gankinterview.cn，或通过售后微信群获取实时帮助。\"\n    },\n    {\n      \"name\": \"什么是内测计划？\",\n      \"description\": \"内测计划为免费试用高级功能的活动，报名人数有限，需联系官方申请。\"\n    }\n  ]\n}",
