    "htmlContent": "{\"functions\":[{\"name\":\"智能问答\",\"description\":\"Luca面壁露卡基于千亿参数大模型，能够理解并回答复杂问题，覆盖科技、教育、生活等多个领域。其多模态能力支持文本和图像的联合输入，提供更精准的答案。\"},{\"name\":\"内容创作\",\"description\":\"支持生成高质量的文章、报告、诗歌等内容，用户可通过简单指令快速获取创意文本。模型具备上下文理解能力，确保生成内容连贯且符合需求。\"},{\"name\":\"知识检索\",\"description\":\"整合海量知识库，提供快速准确的检索服务。用户可通过自然语言提问，获取结构化知识，适用于学术研究、学习辅助等场景。\"}],\"roles\":[{\"name\":\"学生\",\"description\":\"学生可使用Luca面壁露卡进行作业辅助、知识点查询和论文写作。例如，输入问题后，工具会提供详细解答和参考资料，帮助学生高效完成学习任务。\"},{\"name\":\"教育人士\",\"description\":\"教育工作者可利用工具生成教学材料、设计课堂互动内容。例如，输入课程主题后，工具可快速生成教案或习题，节省备课时间。\"},{\"name\":\"科研人员\",\"description\":\"科研人员可通过工具检索学术资料、生成文献综述或技术报告。例如，输入研究方向后，工具会提供相关论文摘要和研究趋势分析。\"}],\"features\":[{\"name\":\"千亿参数大模型\",\"description\":\"Luca面壁露卡基于面壁智能自主研发的千亿参数多模态大模型，具备强大的语义理解和生成能力，支持复杂任务处理和多轮对话。\"},{\"name\":\"免费开放\",\"description\":\"目前工具完全免费开放使用，无需订阅或付费，降低了用户的使用门槛，尤其适合学生和教育工作者。\"},{\"name\":\"多模态交互\",\"description\":\"支持文本和图像的联合输入与输出，扩展了应用场景。例如，用户可上传图片并询问相关问题，模型会结合图像内容生成回答。\"}],\"scenarios\":[{\"name\":\"学术研究辅助\",\"description\":\"科研人员输入研究问题后，工具会检索相关文献并生成综述报告。例如，输入‘量子计算最新进展’，工具会整理关键论文和趋势分析。\"},{\"name\":\"课堂互动设计\",\"description\":\"教师输入课程主题和教学目标，工具生成互动问题和案例分析。例如，输入‘高中物理力学’，工具会设计实验方案和讨论题目。\"}],\"pricing_plan\":[{\"name\":\"免费版\",\"description\":\"目前Luca面壁露卡完全免费，无功能限制，用户可无限次使用所有核心功能。\"}],\"usage\":[{\"name\":\"网页端使用\",\"description\":\"1. 访问官网https://luca-beta.modelbest.cn；2. 在输入框中输入问题或指令；3. 获取生成结果。\"},{\"name\":\"多模态交互\",\"description\":\"1. 点击上传图片按钮；2. 输入与图片相关的问题；3. 模型会结合图像和文本生成回答。\"}],\"questions\":[{\"name\":\"Luca面壁露卡是否收费？\",\"description\":\"目前Luca面壁露卡完全免费，无任何付费计划或功能限制。\"},{\"name\":\"支持哪些类型的多模态输入？\",\"description\":\"支持文本和图像的联合输入，例如上传图片并询问相关问题，模型会结合视觉和语言信息生成回答。\"}]}",
