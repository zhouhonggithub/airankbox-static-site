    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"文本/图片生成3D模型\",\n      \"description\": \"用户只需输入文本描述或上传图片，Fast3D 即可在10秒内自动生成高质量3D模型，适用于零基础用户和专业人士。\"\n    },\n    {\n      \"name\": \"多格式导出\",\n      \"description\": \"支持GLB/GLTF、FBX、OBJ/MTL、STL等主流3D格式导出，兼容主流3D软件、游戏引擎和3D打印流程。\"\n    },\n    {\n      \"name\": \"高保真材质合成\",\n      \"description\": \"AI驱动的PBR材质生成，具备专业级纹理、无缝拼接和智能风格迁移，呈现真实细腻的表面细节。\"\n    },\n    {\n      \"name\": \"多输入模式\",\n      \"description\": \"支持文本生成3D、单图/多视图图片生成3D，操作简单，风格可自定义。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"可快速为动画、游戏、短视频等内容生成独特3D模型，提升创作效率和表现力。\"\n    },\n    {\n      \"name\": \"设计师/开发者\",\n      \"description\": \"设计师和开发者可用Fast3D快速制作原型、产品设计、建筑外观等3D模型，极大缩短设计周期。\"\n    },\n    {\n      \"name\": \"教育工作者/学生\",\n      \"description\": \"用于生成教学用3D模型（如生物、机械等），增强课堂互动和学习兴趣。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"极速生成\",\n      \"description\": \"10秒内完成3D模型生成，极大提升建模效率。\"\n    },\n    {\n      \"name\": \"高精度几何建模\",\n      \"description\": \"支持复杂几何结构的高精度建模，保证模型结构和真实感。\"\n    },\n    {\n      \"name\": \"无需建模经验\",\n      \"description\": \"零基础用户也能轻松上手，无需学习复杂3D软件。\"\n    },\n    {\n      \"name\": \"多行业适用\",\n      \"description\": \"广泛应用于游戏、3D打印、AR/VR、元宇宙、产品设计等领域。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"游戏开发\",\n      \"description\": \"快速生成游戏角色、道具、场景模型，节省开发时间和成本。\"\n    },\n    {\n      \"name\": \"3D打印\",\n      \"description\": \"通过文本或图片生成适合3D打印的模型，直接导出STL格式打印。\"\n    },\n    {\n      \"name\": \"建筑/产品设计\",\n      \"description\": \"快速生成建筑外观、室内空间或产品原型3D模型，用于展示或进一步设计。\"\n    },\n    {\n      \"name\": \"教育教学\",\n      \"description\": \"生成各类教学模型，提升课堂互动和学生参与度。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费版\",\n      \"description\": \"无需信用卡，每月补充1000积分，1个并发任务，每天2次下载，CC BY 4.0授权，有限队列优先级。\"\n    },\n    {\n      \"name\": \"Pro版\",\n      \"description\": \"月付$10（优惠$7），每月补充10000积分，2个并发任务，每天无限下载，标准队列优先级，资产归用户私有，支持PBR纹理和多视图图片转3D。\"\n    },\n    {\n      \"name\": \"Max版\",\n      \"description\": \"月付$20（优惠$14），每月补充30000积分，4个并发任务，每天无限下载，最大化队列优先级，支持Ultra质量，适合团队/工作室。\"\n    },\n    {\n      \"name\": \"Max无限版\",\n      \"description\": \"联系官方定制，每月无限积分、无限并发任务、无限下载，全部功能解锁，适合企业级需求。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"文本/图片生成3D模型\",\n      \"description\": \"1. 访问Fast3D官网；2. 选择免登录或注册登录；3. 输入文本描述或上传图片；4. 设置参数（如网格密度、纹理）；5. 点击生成按钮；6. 预览并选择导出格式下载。\"\n    },\n    {\n      \"name\": \"模型导出与应用\",\n      \"description\": \"1. 生成后在预览页查看模型；2. 选择GLB、FBX、OBJ、STL等格式导出；3. 导入到3D软件或打印设备进行后续编辑或使用。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"生成的3D模型可以商用吗？\",\n      \"description\": \"免费版为CC BY 4.0授权，需署名；Pro及以上版本资产归用户私有，可商用。\"\n    },\n    {\n      \"name\": \"支持哪些导出格式？\",\n      \"description\": \"支持GLB/GLTF、FBX、OBJ/MTL、STL等主流3D格式，兼容主流3D软件和3D打印。\"\n    },\n    {\n      \"name\": \"需要3D建模经验吗？\",\n      \"description\": \"无需建模经验，零基础用户也能快速生成3D模型。\"\n    },\n    {\n      \"name\": \"生成速度如何？\",\n      \"description\": \"一般10秒内即可生成高质量3D模型。\"\n    },\n    {\n      \"name\": \"有API集成吗？\",\n      \"description\": \"支持API集成，适合开发者和企业自动化批量生成需求。\"\n    }\n  ]\n}",
