    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"云端ComfyUI工作流\",\n\t\t\t\"description\": \"基于ComfyUI架构的云端AI创作平台，拥有超7000个预置节点，支持拖拽式工作流构建，实时调试并管理版本，支持Python/JS开发。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"多模态AI生成\",\n\t\t\t\"description\": \"涵盖前沿模型如Stable Diffusion、腾讯混元AI视频模型、Flux、CogVideo等，支持图像生成、视频生成、文本转语音等多种AI创作形式。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"FramePack视频技术\",\n\t\t\t\"description\": \"基于FramePack技术让普通设备能生成高清视频，支持逐帧生成视频的神经网络结构，使生成负载不随视频长度增加。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"批量处理能力\",\n\t\t\t\"description\": \"支持批量处理多张图片，通过ZIP批量上传图片，for循环处理多张图片演示实例，提高创作效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"API集成接口\",\n\t\t\t\"description\": \"提供API接口，将RunningHub工作流集成到用户系统，实现与其他业务系统无缝对接，支持业务逻辑控制工作流调用策略。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"AI创作者\",\n\t\t\t\"description\": \"AI创作者可以使用RunningHub进行图像生成、视频创作、数字人制作等，通过拖拽式工作流快速实现创意想法。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"开发者\",\n\t\t\t\"description\": \"开发者可以基于Python/JS进行二次开发，利用API接口将RunningHub集成到自己的系统中，扩展功能和应用场景。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"企业用户\",\n\t\t\t\"description\": \"企业用户可以在电商、影视、游戏等领域应用RunningHub，加速创作流程，降低创作门槛，实现从分镜脚本到成片的快速转变。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"内容创作者\",\n\t\t\t\"description\": \"内容创作者可以利用RunningHub的云端算力和丰富模型库，进行高质量的内容创作，无需本地部署复杂的AI环境。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"云端算力支持\",\n\t\t\t\"description\": \"提供强大的云端GPU算力，支持高性能AI模型运行，用户无需本地部署复杂环境即可享受专业级AI创作能力。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"丰富模型库\",\n\t\t\t\"description\": \"预装丰富的模型库，涵盖Stable Diffusion、Flux、Cogvideo等海量热门模型，支持多种AI创作需求。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"实时工作流编辑\",\n\t\t\t\"description\": \"支持在线编辑和运行ComfyUI工作流，提供免费的开发环境和工作流编辑功能，让初学者也能轻松上手。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"版本管理\",\n\t\t\t\"description\": \"支持工作流版本管理，实时调试并管理不同版本的工作流，便于迭代优化和团队协作。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"多任务并行\",\n\t\t\t\"description\": \"支持同时运行多个任务，提高创作效率，满足不同用户的使用需求。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"电商内容制作\",\n\t\t\t\"description\": \"电商平台可以利用RunningHub生成产品展示图、宣传视频等营销内容，提升产品展示效果和销售转化率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"影视制作\",\n\t\t\t\"description\": \"影视制作团队可以使用RunningHub进行特效制作、场景生成、数字人制作等，加速后期制作流程。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"游戏开发\",\n\t\t\t\"description\": \"游戏开发者可以利用RunningHub生成游戏素材、角色设计、场景构建等，提高游戏开发效率。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"社交媒体内容\",\n\t\t\t\"description\": \"内容创作者可以使用RunningHub制作短视频、动态图片等社交媒体内容，提升内容质量和吸引力。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费版\",\n\t\t\t\"description\": \"提供免费的开发环境和工作流编辑功能，用户可以体验基本的AI创作功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"按使用付费\",\n\t\t\t\"description\": \"基于实际使用的运行时间付费，标准任务(24G显存)每秒消耗0.2个RH币，Plus任务(48G显存)每秒消耗0.4个RH币。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"API调用费用\",\n\t\t\t\"description\": \"第三方API调用按调用次数计费，如Kontext API等，消耗钱包余额。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"注册登录\",\n\t\t\t\"description\": \"1. 访问RunningHub官网：https://www.runninghub.cn/；2. 完成注册和登录；3. 进入工作台开始创作。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"工作流创建\",\n\t\t\t\"description\": \"1. 在工作台中选择或创建新的工作流；2. 通过拖拽方式添加节点；3. 连接节点构建工作流；4. 设置参数并运行。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"API集成\",\n\t\t\t\"description\": \"1. 获取API接口文档；2. 在您的平台上调用RunningHub工作流；3. 通过API查询工作流的多任务运行状态；4. 设计业务逻辑控制调用策略。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"RunningHub支持哪些AI模型？\",\n\t\t\t\"description\": \"RunningHub支持Stable Diffusion、Flux、CogVideo、腾讯混元AI视频模型、Wan2.1、VACE、FramePack等多种前沿AI模型。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"如何收费？\",\n\t\t\t\"description\": \"RunningHub采用按使用付费模式，基于实际运行时间计费，同时支持免费体验基本功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"是否需要本地部署？\",\n\t\t\t\"description\": \"不需要，RunningHub是云端平台，用户无需本地部署复杂环境，通过浏览器即可使用所有功能。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"支持哪些编程语言？\",\n\t\t\t\"description\": \"RunningHub支持Python和JavaScript开发，用户可以进行二次开发和功能扩展。\"\n\t\t}\n\t]\n}",
