    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"可视化工作流\",\n      \"description\": \"提供拖拽式界面设计 AI 工作流，支持多模型组合和条件分支，开发者无需编写复杂代码即可构建复杂的 AI 应用逻辑。技术特点是基于 React Flow 实现的可视化编排引擎。\"\n    },\n    {\n      \"name\": \"多模型支持\",\n      \"description\": \"集成国内外主流大模型（如 GPT、Claude、文心一言等），支持开发者灵活切换和组合不同模型。创新点在于统一的 API 接口和模型性能监控功能。\"\n    },\n    {\n      \"name\": \"API 管理\",\n      \"description\": \"提供完整的 API 生命周期管理功能，包括密钥管理、流量控制和监控分析。技术特点是基于 Kubernetes 的自动扩缩容能力，保障 API 稳定性。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"开发者\",\n      \"description\": \"开发者可以使用 Dify.AI 快速搭建 AI 应用后端，通过可视化工具降低开发复杂度，利用多模型支持实现最佳效果，大幅缩短产品上线时间。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"内容创作者可以基于平台构建个性化内容生成工具，如自动文章写作、社交媒体文案生成等，通过工作流编排实现内容生产自动化。\"\n    },\n    {\n      \"name\": \"数据分析师\",\n      \"description\": \"数据分析师可以利用平台的模型组合能力，构建复杂的数据分析管道，如自动报告生成、数据可视化解释等，提升分析效率。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"开源可定制\",\n      \"description\": \"平台完全开源，支持私有化部署，企业可以根据需求深度定制。与竞品相比，提供了更高的灵活性和数据安全性。\"\n    },\n    {\n      \"name\": \"企业级功能\",\n      \"description\": \"提供 RBAC 权限管理、审计日志、SLA 保障等企业级功能，适合中大型组织使用。技术团队来自知名 AI 公司，有丰富的大规模部署经验。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"智能客服系统开发\",\n      \"description\": \"开发者通过拖拽方式组合意图识别、问答生成和情感分析模型，配置业务规则后一键部署为 API 服务，3天内完成客服系统开发。\"\n    },\n    {\n      \"name\": \"自动化内容生产\",\n      \"description\": \"内容团队设置工作流：先由 GPT 生成初稿，再通过 Claude 优化语气，最后自动发布到 CMS 系统，实现每日 100+ 篇文章的自动化生产。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"社区版\",\n      \"description\": \"免费使用，支持基础功能，最多 3 个工作流，每月 1000 次 API 调用限制\"\n    },\n    {\n      \"name\": \"专业版\",\n      \"description\": \"$99/月，无限工作流，每月 10 万次 API 调用，优先技术支持\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"定制报价，包含私有化部署、专属模型优化、SLA 保障等企业级功能\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"快速创建应用\",\n      \"description\": \"1. 注册账号 2. 选择模板或新建项目 3. 拖拽组件构建工作流 4. 测试并发布为 API\"\n    },\n    {\n      \"name\": \"API 集成\",\n      \"description\": \"1. 在控制台创建 API Key 2. 查看接口文档 3. 通过 curl 或 SDK 调用 4. 在仪表盘监控使用情况\"\n    }\n  ]\n}",
