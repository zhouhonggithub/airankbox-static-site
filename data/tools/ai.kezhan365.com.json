    "htmlContent": "{\"functions\":[{\"name\":\"智能写作\",\"description\":\"万彩AI提供智能写作功能，能够根据用户输入的关键词或主题，自动生成高质量的文章、广告文案、社交媒体内容等。支持多种写作风格和语言，满足不同场景的需求。\"},{\"name\":\"内容生成\",\"description\":\"万彩AI能够快速生成各类内容，包括新闻稿、产品描述、博客文章等。用户只需输入简单的提示，AI即可生成符合要求的文本内容，大大提升创作效率。\"},{\"name\":\"创意设计\",\"description\":\"万彩AI还提供创意设计功能，支持生成视觉内容，如海报、广告图等。结合AI技术，用户可以轻松获得专业级的设计作品，无需复杂的设计技能。\"}],\"roles\":[{\"name\":\"内容创作者\",\"description\":\"内容创作者可以使用万彩AI快速生成高质量的文章、博客、社交媒体内容等。通过输入关键词或主题，AI能够自动生成符合要求的文本，帮助创作者节省时间，专注于内容优化和发布。\"},{\"name\":\"营销人\",\"description\":\"营销人可以利用万彩AI生成广告文案、产品描述、促销内容等。AI能够根据营销目标和受众特点，生成吸引人的文案，提升广告效果和转化率。\"},{\"name\":\"教育人士\",\"description\":\"教育人士可以使用万彩AI生成教学材料、课程大纲、学习指南等。AI能够根据教育需求，生成结构清晰、内容丰富的教学资源，提升教学效率和质量。\"}],\"features\":[{\"name\":\"多语言支持\",\"description\":\"万彩AI支持多种语言，能够生成符合不同地区和文化背景的内容。无论是中文、英文还是其他语言，AI都能提供高质量的文本输出，满足全球化用户的需求。\"},{\"name\":\"智能优化\",\"description\":\"万彩AI内置智能优化算法，能够根据用户反馈和数据分析，不断优化生成内容的质量和相关性。用户可以通过简单的调整，获得更符合需求的文本和设计。\"}],\"scenarios\":[{\"name\":\"广告文案创作\",\"description\":\"用户输入产品信息和目标受众，万彩AI自动生成多个广告文案选项。用户可以选择最符合需求的文案，并进行微调，最终获得高质量的广告内容。\"},{\"name\":\"社交媒体内容生成\",\"description\":\"用户输入主题或关键词，万彩AI生成适合社交媒体发布的短文、图片描述等。用户可以直接使用或进一步编辑，快速完成社交媒体内容创作。\"}],\"pricing_plan\":[{\"name\":\"免费试用\",\"description\":\"万彩AI提供免费试用版本，用户可以使用基本功能生成有限数量的内容。免费版有部分功能限制，适合个人用户和小规模使用。\"},{\"name\":\"付费版\",\"description\":\"付费版提供更多高级功能和无限制的内容生成。具体价格和功能详情需访问官网或联系客服获取。\"}],\"usage\":[{\"name\":\"文本生成\",\"description\":\"1. 登录万彩AI官网；2. 选择文本生成功能；3. 输入关键词或主题；4. 点击生成按钮；5. 查看并编辑生成的文本。\"},{\"name\":\"创意设计\",\"description\":\"1. 登录万彩AI官网；2. 选择创意设计功能；3. 输入设计需求；4. 选择模板或风格；5. 生成并下载设计作品。\"}],\"questions\":[{\"name\":\"万彩AI是否支持多语言？\",\"description\":\"是的，万彩AI支持多种语言，包括中文、英文等，能够生成符合不同地区和文化背景的内容。\"},{\"name\":\"免费版有哪些限制？\",\"description\":\"免费版可以使用基本功能，但生成的内容数量有限，部分高级功能无法使用。付费版则无这些限制。\"}]}",
