    "htmlContent": "{\"title\":\"Cursor\",\"url\":\"https://www.cursor.com/cn\",\"functions\":[{\"name\":\"AI智能代码补全\",\"description\":\"基于上下文的智能Tab补全功能，能够预测开发者的下一步编辑，提供多行代码建议，让编程更加流畅高效。\"},{\"name\":\"自然语言编程\",\"description\":\"通过Ctrl+K快捷键，开发者可以用自然语言描述需求，AI会自动生成或修改相应的代码，大幅提升开发效率。\"},{\"name\":\"智能聊天助手\",\"description\":\"内置AI聊天功能，能够理解整个代码库上下文，回答代码相关问题，提供代码优化建议和调试帮助。\"},{\"name\":\"代码库理解\",\"description\":\"使用@Codebase功能快速搜索和理解大型代码库，AI能够分析代码结构并提供精准的上下文信息。\"},{\"name\":\"终端集成\",\"description\":\"在终端中使用Ctrl+K，可以用自然语言编写终端命令，AI会自动转换为所需的命令格式。\"},{\"name\":\"多模态交互\",\"description\":\"支持图像输入和@Web网络搜索，可以将视觉内容或最新信息整合到编程工作流中。\"},{\"name\":\"Agent自动化\",\"description\":\"Agent模式可以端到端完成复杂任务，包括自动检测和修复lint错误，执行命令等自动化操作。\"},{\"name\":\"即时应用\",\"description\":\"聊天中生成的代码可以通过点击播放按钮直接应用到代码库中，无需手动复制粘贴。\"}],\"roles\":[{\"name\":\"软件开发者\",\"description\":\"提供智能代码补全、自动化调试、代码重构等功能，显著提升编程效率和代码质量。\"},{\"name\":\"内容创作者\",\"description\":\"帮助技术文档编写、API文档生成、代码注释优化，让技术内容创作更加高效。\"},{\"name\":\"教育人士\",\"description\":\"辅助编程教学，提供代码解释、生成教学示例、创建交互式编程课程内容。\"},{\"name\":\"科研人员\",\"description\":\"支持学术研究中的代码实现、数据分析脚本编写、研究工具开发等科研编程需求。\"}],\"features\":[{\"name\":\"SOC 2认证\",\"description\":\"通过SOC 2 Type II认证，提供企业级安全保障，支持隐私模式确保代码安全。\"},{\"name\":\"VSCode兼容\",\"description\":\"完美兼容VSCode扩展、主题和快捷键，用户可以无缝迁移现有的开发环境配置。\"},{\"name\":\"前沿AI模型\",\"description\":\"集成OpenAI、Anthropic、Gemini等最新AI模型，结合自定义优化模型提供最佳性能。\"},{\"name\":\"企业级支持\",\"description\":\"提供SAML 2.0 SSO集成、团队管理、使用分析等企业级功能，适合大型开发团队使用。\"},{\"name\":\"开源友好\",\"description\":\"在GitHub上开源，拥有30.3k stars，活跃的社区支持和持续的功能更新。\"}],\"scenarios\":[{\"name\":\"快速代码生成\",\"description\":\"\\\"创建一个React组件来处理用户登录\\\" - AI会自动生成完整的组件代码包括状态管理和表单验证。\"},{\"name\":\"代码重构优化\",\"description\":\"\\\"将这个函数重构为更高效的版本\\\" - AI分析现有代码并提供性能优化的重构建议。\"},{\"name\":\"错误调试助手\",\"description\":\"\\\"这里有什么bug吗？\\\" - AI分析当前代码上下文，识别潜在问题并提供修复方案。\"},{\"name\":\"API文档生成\",\"description\":\"\\\"为这个API端点生成文档\\\" - AI分析代码结构自动生成详细的API文档和使用示例。\"},{\"name\":\"技术学习辅导\",\"description\":\"\\\"解释这段代码的工作原理\\\" - AI提供详细的代码解析和相关技术概念说明。\"}]}",
