    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"多Agent博弈系统\",\n      \"description\": \"通过多个专业AI Agent协作，模拟市场参与者行为，分析市场趋势和风险点，生成综合金融分析报告。\"\n    },\n    {\n      \"name\": \"MCP智能调用\",\n      \"description\": \"基于Model Context Protocol技术，实现模型间无缝协作，支持即插即用的金融工具生态。\"\n    },\n    {\n      \"name\": \"风险预警系统\",\n      \"description\": \"实时监控市场异常，提前识别潜在风险，为金融分析提供安全保障。\"\n    },\n    {\n      \"name\": \"实时数据处理\",\n      \"description\": \"毫秒级处理海量金融数据，支持即时分析和策略调整。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"投资者\",\n      \"description\": \"提供全面的股票分析和投资组合优化建议，帮助用户做出更明智的投资决策。\"\n    },\n    {\n      \"name\": \"金融机构\",\n      \"description\": \"提升风险管理能力，优化信贷分析，加强投资分析，改善客户服务体验。\"\n    },\n    {\n      \"name\": \"量化交易者\",\n      \"description\": \"提供量化交易信号和策略优化建议，帮助捕捉交易机会，提高交易效率和收益。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"双环境架构\",\n      \"description\": \"集成Research环境进行多智能体协作分析与Battle环境的结构化辩论，模拟真实市场研究和决策过程。\"\n    },\n    {\n      \"name\": \"无缝信息流转\",\n      \"description\": \"实现从Research环境到Battle环境的完整分析结果传递，确保信息在不同阶段间的连贯性。\"\n    },\n    {\n      \"name\": \"累积式辩论\",\n      \"description\": \"通过累积之前所有专家的讨论内容，促进更深入和全面的分析讨论。\"\n    },\n    {\n      \"name\": \"持续性状态管理\",\n      \"description\": \"维护分析过程的持续性和上下文的一致性，以保障决策的精确度和分析的可靠性。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"投资决策支持\",\n      \"description\": \"为投资者提供全面的股票分析和投资组合优化建议，帮助用户做出更明智的投资决策。\"\n    },\n    {\n      \"name\": \"风险管理\",\n      \"description\": \"实时监控市场异常，提前识别潜在风险点，为金融机构提供风险预警和评估，帮助其有效规避风险。\"\n    },\n    {\n      \"name\": \"市场趋势分析\",\n      \"description\": \"实时掌握市场动态和行业趋势，帮助投资者和机构把握市场走向。\"\n    },\n    {\n      \"name\": \"量化交易\",\n      \"description\": \"提供量化交易信号和策略优化建议，帮助量化交易者捕捉交易机会，提高交易效率和收益。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"基础版\",\n      \"description\": \"¥2,999/月，适合小型金融机构和初创企业，包含基础多Agent博弈模型、每日数据分析报告、基础风险预警、5个用户账号、标准客户支持。\"\n    },\n    {\n      \"name\": \"专业版\",\n      \"description\": \"¥7,999/月，适合中型金融机构和投资公司，包含高级多Agent博弈模型、实时数据分析与报告、高级风险预警与管理、MCP智能调用功能、20个用户账号、优先客户支持、API接口访问。\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"定制，适合大型金融机构和银行，包含定制多Agent博弈系统、全面数据分析解决方案、企业级风险管理系统、高级MCP智能调用、无限用户账号、24/7专属客户支持、完整API与SDK、专属部署方案。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"注册和登录\",\n      \"description\": \"访问 FinGenius 官网或下载移动应用，创建账户并登录。\"\n    },\n    {\n      \"name\": \"开始使用\",\n      \"description\": \"通过多智能体分析模拟市场行为以获取趋势和风险点，用MCP实现模型协作进行金融数据分析，依靠风险预警系统监控异常并识别风险。\"\n    },\n    {\n      \"name\": \"定制化设置\",\n      \"description\": \"根据个人投资习惯和偏好，设置定制化的分析参数和预警条件。\"\n    },\n    {\n      \"name\": \"监控和分析\",\n      \"description\": \"监控 FinGenius 提供的分析报告和预警信息，进行投资决策。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"支持哪些用户类型？\",\n      \"description\": \"支持个人投资者、金融机构、量化交易者等多种用户类型。\"\n    },\n    {\n      \"name\": \"如何保障数据安全？\",\n      \"description\": \"企业版支持专属部署，数据独立运行，保障安全性。\"\n    },\n    {\n      \"name\": \"是否支持API集成？\",\n      \"description\": \"专业版及以上支持API接口访问，便于与现有系统集成。\"\n    },\n    {\n      \"name\": \"是否提供免费试用？\",\n      \"description\": \"所有方案均包含14天免费试用，无需信用卡，随时取消。\"\n    }\n  ]\n}",
