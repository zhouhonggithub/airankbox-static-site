    "screenshot_url": "/images/tools/chatglm.png",
    "htmlContent": "{\n  \"title\": \"ChatGLM\",\n  \"url\": \"https://chatglm.cn/\",\n  \"functions\": [\n    {\n      \"name\": \"GLM架构对话\",\n      \"description\": \"基于创新的GLM(General Language Model)架构，具备强大的自然语言理解和生成能力。\"\n    },\n    {\n      \"name\": \"中英双语支持\",\n      \"description\": \"原生支持中英文双语对话，在中文理解和生成方面表现尤为出色。\"\n    },\n    {\n      \"name\": \"多轮对话记忆\",\n      \"description\": \"具备上下文记忆能力，支持长时间、多轮次的连续对话交流。\"\n    },\n    {\n      \"name\": \"知识推理能力\",\n      \"description\": \"强大的逻辑推理和知识问答能力，能够进行复杂的思维推理过程。\"\n    },\n    {\n      \"name\": \"代码理解生成\",\n      \"description\": \"支持多种编程语言的代码理解、生成、调试和优化功能。\"\n    },\n    {\n      \"name\": \"文本创作助手\",\n      \"description\": \"优秀的文本创作能力，支持各种文体和风格的内容生成。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"学生\",\n      \"description\": \"学习辅导、作业帮助、知识问答，提供个性化的教育支持服务。\"\n    },\n    {\n      \"name\": \"科研人员\",\n      \"description\": \"学术研究支持、文献分析、论文写作，助力科研工作效率提升。\"\n    },\n    {\n      \"name\": \"开发者\",\n      \"description\": \"代码编写、技术问答、程序调试，全方位的编程开发支持。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"创意写作、文案策划、内容生成，激发创作灵感和提升创作效率。\"\n    },\n    {\n      \"name\": \"办公人员\",\n      \"description\": \"文档处理、邮件撰写、信息整理，提升日常办公工作效率。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"清华智谱AI技术\",\n      \"description\": \"由清华大学KEG实验室和智谱AI联合开发，具备深厚的学术研究背景。\"\n    },\n    {\n      \"name\": \"开源开放\",\n      \"description\": \"提供开源版本，促进AI技术的普及和发展，支持社区贡献。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"学术研究辅助\",\n      \"description\": \"协助进行文献调研、数据分析、论文写作等学术工作，为科研人员提供智能化的研究支持工具。\"\n    },\n    {\n      \"name\": \"编程开发助手\",\n      \"description\": \"提供代码生成、调试建议、技术文档编写等开发支持，帮助程序员提高开发效率和代码质量。\"\n    },\n    {\n      \"name\": \"智能客服对话\",\n      \"description\": \"构建智能客服系统，提供7x24小时的自动化客户服务，处理常见问题和用户咨询。\"\n    },\n    {\n      \"name\": \"教育培训平台\",\n      \"description\": \"作为智能教师助手，提供个性化学习指导、答疑解惑、知识点讲解等教育服务。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费体验\",\n      \"description\": \"提供免费试用额度，用户可以体验基础的对话和问答功能。\"\n    },\n    {\n      \"name\": \"ChatGLM Pro\",\n      \"description\": \"专业版提供更高的使用频次、更快的响应速度和优先技术支持。\"\n    },\n    {\n      \"name\": \"企业定制\",\n      \"description\": \"为企业用户提供私有化部署、API接口调用和定制化开发服务。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"在线对话平台\",\n      \"description\": \"直接访问chatglm.cn开始对话体验，支持微信、手机号等多种登录方式。界面友好，操作简单，支持连续对话和上下文理解。\"\n    },\n    {\n      \"name\": \"API接口调用\",\n      \"description\": \"开发者可通过RESTful API接口集成ChatGLM能力到自己的应用中，支持多种编程语言SDK，方便快速集成开发。\"\n    },\n    {\n      \"name\": \"本地部署版本\",\n      \"description\": \"提供开源版本支持本地部署，企业可在内网环境中独立运行，保障数据安全和隐私，满足特殊合规要求。\"\n    }\n  ]\n}",
