    "screenshot_url": "/images/tools/kimi.png",
    "htmlContent": "{\n  \"title\": \"Kimi\",\n  \"url\": \"https://www.kimi.com/\",\n  \"functions\": [\n    {\n      \"name\": \"超长文本处理\",\n      \"description\": \"支持高达200万字的超长文本输入，能够完整理解和分析大型文档、学术论文、技术手册等长篇内容。\"\n    },\n    {\n      \"name\": \"多格式文件解析\",\n      \"description\": \"支持PDF、Word、Excel、PPT、TXT等多种格式文件的上传和解析，智能提取关键信息。\"\n    },\n    {\n      \"name\": \"智能联网搜索\",\n      \"description\": \"具备实时联网搜索能力，能够获取最新信息并结合搜索结果提供准确回答。\"\n    },\n    {\n      \"name\": \"深度推理分析\",\n      \"description\": \"Kimi k1.5版本具备强化学习能力，能够进行复杂推理和自我反思，提供更准确的分析结果。\"\n    },\n    {\n      \"name\": \"多语言对话\",\n      \"description\": \"支持中英文等多种语言的自然对话，理解能力强，回应准确自然。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"学术科研人员\",\n      \"description\": \"快速阅读分析大量文献，协助论文写作，提供研究思路和数据分析支持。\"\n    },\n    {\n      \"name\": \"商务专业人士\",\n      \"description\": \"分析商业报告，处理合同文件，制定商业策略，提高工作效率。\"\n    },\n    {\n      \"name\": \"学生\",\n      \"description\": \"辅助学习和论文写作，快速理解复杂教材，提供学习指导和答疑。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"协助内容创作，提供写作灵感，分析热点话题，优化创作流程。\"\n    },\n    {\n      \"name\": \"法律从业者\",\n      \"description\": \"分析法律文件，查找相关法条，协助案例研究和法律文书写作。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"记忆能力强\",\n      \"description\": \"具备强大的上下文记忆能力，能够在长对话中保持信息的连贯性和一致性。\"\n    },\n    {\n      \"name\": \"中文优化\",\n      \"description\": \"专门针对中文语境优化，更好地理解中文表达习惯和文化背景。\"\n    },\n    {\n      \"name\": \"实时更新\",\n      \"description\": \"持续更新和改进，定期推出新功能和性能优化，保持技术领先性。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"学术研究辅助\",\n      \"description\": \"\\\"分析这10篇相关论文的核心观点差异\\\" - 快速提取多篇论文要点，进行对比分析，为研究提供支持。\"\n    },\n    {\n      \"name\": \"商业文档分析\",\n      \"description\": \"\\\"总结这份200页的市场报告的关键发现\\\" - 快速提取报告核心信息，生成执行摘要。\"\n    },\n    {\n      \"name\": \"学习辅导\",\n      \"description\": \"\\\"帮我理解这本教科书的第五章内容\\\" - 深度解析教材内容，提供清晰的知识点梳理。\"\n    },\n    {\n      \"name\": \"创作支持\",\n      \"description\": \"\\\"基于这些素材为我写一篇深度分析文章\\\" - 整合多源信息，生成高质量的原创内容。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费版本\",\n      \"description\": \"提供基础的对话功能和文档处理能力，满足日常使用需求。\"\n    },\n    {\n      \"name\": \"会员服务\",\n      \"description\": \"提供更高的使用限额、优先处理权限和高级功能访问，适合重度用户。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"访问https://kimi.moonshot.cn直接使用，支持文档上传、网页链接分析等功能。界面简洁友好，上传文档后即可开始智能问答和内容分析，支持多轮对话保持上下文。\"\n    },\n    {\n      \"name\": \"移动端应用\",\n      \"description\": \"下载Kimi智能助手APP，随时随地使用AI助手功能。支持语音输入、拍照识别等移动端特色功能，与网页端数据同步，使用体验一致。\"\n    },\n    {\n      \"name\": \"微信小程序\",\n      \"description\": \"在微信中搜索\\\"Kimi智能助手\\\"小程序，无需单独下载APP即可使用。适合轻度使用场景，支持基础的对话和文档处理功能，使用便捷。\"\n    }\n  ]\n}",
