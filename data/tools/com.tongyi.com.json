    "htmlContent": "{\n  \"title\": \"通义千问\",\n  \"url\": \"https://www.tongyi.com/\",\n  \"functions\": [\n    {\n      \"name\": \"多模态理解与生成\",\n      \"description\": \"支持文本、图像、音频、视频多种模态的理解和生成，具备完整的多模态处理能力。\"\n    },\n    {\n      \"name\": \"超长文本处理\",\n      \"description\": \"支持最长1000万字的超长文本理解和处理，适合处理大型文档和复杂任务。\"\n    },\n    {\n      \"name\": \"AI智能搜索\",\n      \"description\": \"集成实时搜索能力，提供最新信息查询和智能信息整理功能。\"\n    },\n    {\n      \"name\": \"代码编程助手\",\n      \"description\": \"支持多种编程语言的代码生成、调试、优化和解释，助力开发效率提升。\"\n    },\n    {\n      \"name\": \"文档与PPT生成\",\n      \"description\": \"智能生成各类文档、报告、演示文稿，支持多种格式和风格定制。\"\n    },\n    {\n      \"name\": \"插件生态系统\",\n      \"description\": \"丰富的插件扩展功能，覆盖办公、娱乐、学习等多个场景应用。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"多模态内容创作、文案策划、创意写作，支持各种媒体形式的内容生成。\"\n    },\n    {\n      \"name\": \"企业决策者\",\n      \"description\": \"商业分析、市场研究、战略规划，提供数据驱动的决策支持。\"\n    },\n    {\n      \"name\": \"开发者\",\n      \"description\": \"代码生成、技术文档编写、API集成开发，全面的编程支持。\"\n    },\n    {\n      \"name\": \"学生\",\n      \"description\": \"学习辅导、论文写作、知识问答，个性化的教育助手服务。\"\n    },\n    {\n      \"name\": \"营销人员\",\n      \"description\": \"营销文案、广告创意、用户画像分析，全方位营销支持。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"阿里云技术支撑\",\n      \"description\": \"基于阿里云强大的计算和技术基础设施，保障服务稳定性和安全性。\"\n    },\n    {\n      \"name\": \"企业级安全\",\n      \"description\": \"提供企业级数据安全保护和隐私保障机制。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"智能办公助手\",\n      \"description\": \"帮助处理日常办公任务，如文档撰写、邮件回复、日程安排、数据分析等，显著提升工作效率。\"\n    },\n    {\n      \"name\": \"教育培训辅导\",\n      \"description\": \"提供个性化学习指导、课业辅导、知识问答等教育服务，适合各年龄段学习者使用。\"\n    },\n    {\n      \"name\": \"创意内容生产\",\n      \"description\": \"协助创作各类文字、图像、视频内容，为创意工作者提供灵感和技术支持。\"\n    },\n    {\n      \"name\": \"企业智能决策\",\n      \"description\": \"基于大数据分析提供商业洞察和决策建议，帮助企业制定更科学的发展策略。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费额度\",\n      \"description\": \"提供每日免费使用额度，支持基础对话和文本生成功能。\"\n    },\n    {\n      \"name\": \"通义千问Plus\",\n      \"description\": \"付费版本提供更高的使用限额、优先处理和高级功能访问权限。\"\n    },\n    {\n      \"name\": \"企业版\",\n      \"description\": \"面向企业用户的定制化解决方案，包含私有部署、API调用和专业技术支持。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"直接访问www.tongyi.com即可使用，支持手机号或淘宝账号登录。界面简洁易用，支持文本、语音、图片多种输入方式，实时获得AI回复和帮助。\"\n    },\n    {\n      \"name\": \"移动APP应用\",\n      \"description\": \"下载通义APP，随时随地享受AI服务。支持语音对话、拍照识别、离线功能等移动端专属特性，满足移动办公和学习需求。\"\n    },\n    {\n      \"name\": \"插件与集成\",\n      \"description\": \"支持浏览器插件、Office插件、开发者API等多种集成方式。可轻松嵌入现有工作流程，通过插件系统扩展更多专业功能和应用场景。\"\n    }\n  ]\n}",
