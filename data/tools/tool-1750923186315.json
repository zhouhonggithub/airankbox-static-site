    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"游戏陪伴\",\n      \"description\": \"逗逗AI能够模拟真实对话，提供游戏策略建议和角色扮演互动，增强用户的游戏体验。通过自然语言处理技术，AI能够理解用户需求并做出智能回应。\"\n    },\n    {\n      \"name\": \"角色扮演\",\n      \"description\": \"用户可以与逗逗AI进行角色扮演互动，AI会根据设定角色做出相应反应，提供沉浸式的游戏体验。\"\n    },\n    {\n      \"name\": \"策略建议\",\n      \"description\": \"逗逗AI能够根据游戏场景提供策略建议，帮助用户更好地完成游戏任务或挑战。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"内容创作者可以使用逗逗AI生成游戏剧情或对话内容，丰富创作素材。AI的互动能力可以帮助创作者测试剧情逻辑和角色设定。\"\n    },\n    {\n      \"name\": \"学生\",\n      \"description\": \"学生可以通过与逗逗AI的互动放松心情，同时锻炼逻辑思维和语言表达能力。AI的游戏策略建议也能帮助学生提升游戏技巧。\"\n    },\n    {\n      \"name\": \"开发者\",\n      \"description\": \"开发者可以利用逗逗AI的API接口，将其集成到自己的游戏或应用中，增强产品的互动性和智能化水平。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"自然语言处理\",\n      \"description\": \"逗逗AI采用先进的自然语言处理技术，能够理解并回应用户的复杂对话需求，提供流畅的互动体验。\"\n    },\n    {\n      \"name\": \"角色定制\",\n      \"description\": \"用户可以根据需求定制AI的角色设定，使其更符合特定游戏场景或互动需求。\"\n    },\n    {\n      \"name\": \"国内模型\",\n      \"description\": \"逗逗AI基于国内开发的AI模型，针对中文用户优化，提供更符合本土用户习惯的互动体验。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"游戏剧情互动\",\n      \"description\": \"用户在游戏中遇到剧情分支时，可以与逗逗AI互动，AI会根据剧情发展提供对话选项或策略建议，帮助用户推进游戏进程。\"\n    },\n    {\n      \"name\": \"角色扮演练习\",\n      \"description\": \"用户可以通过与逗逗AI的角色扮演互动，练习特定角色的对话和行为模式，提升表演或创作能力。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费版\",\n      \"description\": \"提供基础的游戏陪伴和角色扮演功能，每日互动次数有限制。\"\n    },\n    {\n      \"name\": \"付费版\",\n      \"description\": \"解锁高级功能，包括无限制互动、角色定制等，具体价格请参考官网最新信息。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页版使用\",\n      \"description\": \"1. 访问逗逗AI官网；2. 注册或登录账号；3. 选择游戏或互动模式；4. 开始与AI互动。\"\n    },\n    {\n      \"name\": \"API集成\",\n      \"description\": \"1. 申请开发者API密钥；2. 按照文档集成到自己的应用中；3. 配置互动参数；4. 测试并上线。\"\n    }\n  ]\n}",
