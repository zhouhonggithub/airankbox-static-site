    "htmlContent": "{\n\t\"functions\": [{\n\t\t\t\"name\": \"智能重命名\",\n\t\t\t\"description\": \"Wisfile 能够深入分析 Word、PDF 等文件的内容，自动提取标题、作者、年份等关键信息，并根据这些信息批量重命名文件，告别混乱无序的文件名。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"自定义命名规则\",\n\t\t\t\"description\": \"用户可以根据个人或团队的需求，创建灵活的命名模板（如“项目-日期-文档类型”），让工具按照统一规范批量重命名文件，实现标准化管理。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"AI 自动分类归档\",\n\t\t\t\"description\": \"工具能智能识别文件的学科领域、项目主题或期刊名称，并自动将重命名后的文件归类到相应的文件夹中，实现整理和归档一步到位。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"批量处理\",\n\t\t\t\"description\": \"支持一次性拖入大量文件或整个文件夹进行处理，无论是重命名还是分类，都能批量完成，极大地提升了文件整理的效率。\"\n\t\t}\n\t],\n\t\"roles\": [{\n\t\t\t\"name\": \"学术研究者与学生\",\n\t\t\t\"description\": \"需要处理大量命名不规范的学术论文和文献，Wisfile可以根据论文内容自动重命名并按学科分类，便于查找和引用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"项目经理与办公人员\",\n\t\t\t\"description\": \"面对来自不同来源、命名混乱的项目文件和工作报告，可以使用自定义模板进行批量重命名和归档，确保团队文件规范统一。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"教师与教育工作者\",\n\t\t\t\"description\": \"收集了大量教学材料和课件，可利用Wisfile按“朝代-主题”等方式自动整理，快速建立结构化的教学资源库。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"设计师与律师\",\n\t\t\t\"description\": \"需要管理按项目、客户或案件分类的大量设计稿或法律文书，Wisfile的智能整理功能可以帮助他们快速将文件归档到正确的目录中。\"\n\t\t}\n\t],\n\t\"features\": [{\n\t\t\t\"name\": \"100% 本地运行\",\n\t\t\t\"description\": \"所有的AI分析和文件处理完全在用户本地电脑上进行，无需联网，确保了文件的隐私和安全，不存在数据泄露的风险。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"完全免费\",\n\t\t\t\"description\": \"Wisfile 是一款完全免费的工具，所有功能均可免费使用，无需注册或付费，没有任何隐藏费用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"内容感知AI\",\n\t\t\t\"description\": \"其核心AI技术能够理解文件内部的实际内容，而不仅仅是基于文件名或元数据，从而实现真正意义上的智能整理。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"跨平台支持\",\n\t\t\t\"description\": \"目前主要提供 macOS 版本下载，但官网也提供了在线演示（Online Demo），方便不同平台的用户体验其核心功能。\"\n\t\t}\n\t],\n\t\"scenarios\": [{\n\t\t\t\"name\": \"整理下载的学术论文\",\n\t\t\t\"description\": \"将下载的一堆类似“Ogvh2345.pdf”的论文拖入Wisfile，AI自动识别并将其重命名为“作者-年份-标题.pdf”，并按学科分类存放。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"规范化项目文档\",\n\t\t\t\"description\": \"项目经理设定命名规则为“项目名-日期-文件类型”，然后将所有相关文件导入，一键完成所有文档的标准化重命名和归档。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"清理杂乱的下载文件夹\",\n\t\t\t\"description\": \"将长期未整理的下载文件夹整个导入Wisfile，工具会自动识别各类文件内容，并将其分门别类地放入不同文件夹，同时进行智能重命名。\"\n\t\t}\n\t],\n\t\"pricing_plan\": [{\n\t\t\t\"name\": \"免费\",\n\t\t\t\"description\": \"该产品完全免费，用户可以无限制地使用其所有功能，包括AI重命名和自动归档，没有任何费用。\"\n\t\t}\n\t],\n\t\"usage\": [{\n\t\t\t\"name\": \"批量重命名文件\",\n\t\t\t\"description\": \"1. 访问官网下载并安装应用；2. 启动程序并导入需要整理的文件或文件夹；3. AI将自动识别文件内容；4. 选择一个预设模板或自定义命名规则；5. 点击“开始重命名”即可完成。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"自动分类文件\",\n\t\t\t\"description\": \"1. 导入文件后，启用AI识别功能；2. Wisfile会自动分析文件内容并建议分类；3. 确认或调整分类规则；4. 执行操作，文件将被自动移动到按主题或类型命名的文件夹中。\"\n\t\t}\n\t],\n\t\"questions\": [{\n\t\t\t\"name\": \"使用 Wisfile 是否需要付费？\",\n\t\t\t\"description\": \"不需要。根据其官网信息，Wisfile是一款完全免费的工具，所有功能都可以免费使用。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"我的文件数据是否安全？\",\n\t\t\t\"description\": \"非常安全。Wisfile是一个100%在本地运行的应用程序，所有处理过程都在您的电脑上完成，文件不会被上传到任何服务器，没有数据泄露的风险。\"\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Wisfile 支持哪些操作系统？\",\n\t\t\t\"description\": \"目前官方网站主要提供针对 Mac 操作系统的下载版本。同时提供在线Demo供用户体验。\"\n\t\t}\n\t]\n}",
