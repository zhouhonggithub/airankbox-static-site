    "screenshot_url": "/images/tools/__AI_first.png",
    "htmlContent": "{\n  \"functions\": [\n    {\n      \"name\": \"国风AI绘画创作\",\n      \"description\": \"核心功能，用户通过输入中文文字描述（咒语），即可由AI智能生成具有中式传统审美的国风艺术作品，如水墨画、插画、皮影戏等风格。\"\n    },\n    {\n      \"name\": \"多样化风格模板\",\n      \"description\": \"平台内置了丰富的国风艺术风格模板，如图案、刺绣、传统国画、现代插画等，用户可以一键选用，快速开启创作，降低使用门槛。\"\n    },\n    {\n      \"name\": \"创作者社区\",\n      \"description\": \"提供一个充满活力的艺术交流社区，用户可以分享自己的AI作品，与其他创作者交流心得、互相启发，并可将作品发布到更广阔的平台。\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"name\": \"艺术创作者\",\n      \"description\": \"无论是专业插画师、艺术家还是业余爱好者，都可以利用奇域AI快速将脑海中的创意转化为具有中式美学的视觉艺术品。\"\n    },\n    {\n      \"name\": \"设计师\",\n      \"description\": \"设计师可以利用奇域AI生成的国风元素或插画，作为设计素材应用于广告、产品包装、UI界面等，丰富设计内容，提升独特性。\"\n    },\n    {\n      \"name\": \"内容创作者\",\n      \"description\": \"博客作者、视频博主等内容创作者可以使用平台生成的独特国风图片，作为文章配图或视频素材，增强内容的视觉吸引力。\"\n    }\n  ],\n  \"features\": [\n    {\n      \"name\": \"专注中式审美\",\n      \"description\": \"奇域AI的AI模型深植于中国传统文化，经过大量国风艺术品训练，旨在精准捕捉并再现书法、绘画、建筑等领域的中式美学特点。\"\n    },\n    {\n      \"name\": \"灵活的图片比例\",\n      \"description\": \"支持生成多种常见的图片比例，如3:4、16:9、1:1等，满足用户在不同应用场景（如手机壁纸、社交媒体帖子）下的创作需求。\"\n    },\n    {\n      \"name\": \"个性化咒语创作\",\n      \"description\": \"除了使用预设模板，平台也支持用户完全自定义提示词（咒语），给予创作者高度的自由度，以实现更个性化和多样化的艺术表达。\"\n    }\n  ],\n  \"scenarios\": [\n    {\n      \"name\": \"创作水墨风格插画\",\n      \"description\": \"用户在输入框描述“云雾缭绕的黄山奇松”，然后选择“水墨画”风格模板和16:9的图片比例，AI即可生成四张不同构图的水墨风格作品供用户挑选。\"\n    },\n    {\n      \"name\": \"设计节日海报\",\n      \"description\": \"为制作中秋节主题海报，设计师输入“嫦娥奔月，桂树，玉兔”，选用“现代插画”风格，生成一张具有节日氛围和现代美感的插画作为海报主视觉。\"\n    },\n    {\n      \"name\": \"获取社交媒体配图\",\n      \"description\": \"内容创作者在发布一首关于“江南”的古诗时，可以使用奇域AI生成一张“烟雨朦胧的江南古镇”图片作为配图，提升帖子的意境和吸引力。\"\n    }\n  ],\n  \"pricing_plan\": [\n    {\n      \"name\": \"免费内测\",\n      \"description\": \"目前产品处于免费内测阶段。新用户注册即送100额度，每日签到可再获100额度。生成低分辨率图片消耗1额度，高分辨率消耗5额度。\"\n    },\n    {\n      \"name\": \"额度获取\",\n      \"description\": \"除了注册和签到，用户还可以通过推荐好友（+200额度）或自己的作品被他人点亮（+50额度）等方式免费获取更多创作额度。\"\n    },\n    {\n      \"name\": \"未来付费计划\",\n      \"description\": \"官方未来可能会推出付费购买额度或订阅会员的计划，以提供更稳定和高级的服务，具体方案待公布。\"\n    }\n  ],\n  \"usage\": [\n    {\n      \"name\": \"网页端使用\",\n      \"description\": \"1. 访问奇域AI官网(qiyuai.net)并注册登录；2. 在页面底部的输入框内填写描述画面的提示词；3. 选择图片尺寸和艺术风格；4. 点击“生成”按钮等待AI创作；5. 在生成的作品中选择满意的进行下载或分享。\"\n    },\n    {\n      \"name\": \"移动端使用\",\n      \"description\": \"奇域AI也支持在微信小程序中使用，用户可以在微信中搜索“奇域AI”，操作流程与网页端基本一致，方便在手机上随时随地进行创作。\"\n    }\n  ],\n  \"questions\": [\n    {\n      \"name\": \"奇域AI支持哪些具体的国风风格？\",\n      \"description\": \"根据其介绍，奇域AI支持包括但不限于传统国画、水墨画、现代插画、刺绣、皮影戏、京剧等多种具有中国文化特色的艺术风格。\"\n    },\n    {\n      \"name\": \"免费额度用完了怎么办？\",\n      \"description\": \"您可以通过每日签到、推荐新用户或发布受欢迎的作品来持续免费获取额度。在当前的免费内测阶段，这些是主要的额度补充方式。\"\n    },\n    {\n      \"name\": \"生成的图片可以用于商业用途吗？\",\n      \"description\": \"关于商业使用的具体条款，建议查阅官网的用户协议或服务条款。通常在内测阶段，平台可能会对商业使用有所限制，或在未来推出专门的商业授权计划。\"\n    }\n  ]\n}",
